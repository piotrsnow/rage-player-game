    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.2.0",
    "@google-cloud/storage": "^7.0.0",
    "@google-cloud/tasks": "^5.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
