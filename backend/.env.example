# Server
PORT=3001
HOST=0.0.0.0

# Database (Postgres 16 + pgvector)
# LOCAL MODE (default — host-side prisma migrate against compose `db` service):
DATABASE_URL="postgresql://rpgon:rpgon@localhost:5432/rpgon"
# NEON MODE (managed — mirror the same value as root `.env`):
# DATABASE_URL="postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<database>?sslmode=require"

# JWT
JWT_SECRET="__GENERATED__"

# Media storage backend: "local" or "gcp"
MEDIA_BACKEND="local"

# Local media storage path (relative to backend root)
MEDIA_LOCAL_PATH="./media"

# GCP Cloud Storage
GCS_BUCKET_NAME=""
GOOGLE_APPLICATION_CREDENTIALS=""
# Or inline JSON key:
# GCP_SERVICE_ACCOUNT_KEY=""

# Optional: default API keys (users can also store their own)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
ELEVENLABS_API_KEY=""
STABILITY_API_KEY=""
GEMINI_API_KEY=""

# Encryption key for user API keys stored in DB (32 hex chars)
API_KEY_ENCRYPTION_SECRET="__GENERATED__"

# CORS origin: "true" to allow any origin (dev), URL string, or comma-separated URLs
CORS_ORIGIN=true
