# Server
PORT=3001
HOST=0.0.0.0

# Database (SQLite for local dev, change to postgresql:// for production)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="change-me-to-a-random-secret"

# Media storage backend: "local" or "gcp"
MEDIA_BACKEND="local"

# Local media storage path (relative to backend root)
MEDIA_LOCAL_PATH="./media"

# GCP Cloud Storage
GCS_BUCKET_NAME=""
GOOGLE_APPLICATION_CREDENTIALS=""
# Or inline JSON key:
# GCP_SERVICE_ACCOUNT_KEY=""

# Optional: default API keys (users can also store their own)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
ELEVENLABS_API_KEY=""
STABILITY_API_KEY=""
SUNO_API_KEY=""

# Encryption key for user API keys stored in DB (32 hex chars)
API_KEY_ENCRYPTION_SECRET="change-me-to-32-char-hex-secret"

# CORS origin: "true" to allow any origin (dev), URL string, or comma-separated URLs
CORS_ORIGIN=true
