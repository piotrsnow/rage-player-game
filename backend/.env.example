# Server
PORT=3001
HOST=0.0.0.0

# Database (Postgres 16 + pgvector)
# LOCAL MODE (default — host-side prisma migrate against compose `db` service):
DATABASE_URL="postgresql://rpgon:rpgon@localhost:5432/rpgon"
# NEON MODE (managed — mirror the same value as root `.env`):
# DATABASE_URL="postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<database>?sslmode=require"

# JWT
JWT_SECRET="__GENERATED__"

# Media storage backend: "local" or "gcp"
MEDIA_BACKEND="local"

# Local media storage path (relative to backend root)
MEDIA_LOCAL_PATH="./media"

# GCP Cloud Storage
GCS_BUCKET_NAME=""
GOOGLE_APPLICATION_CREDENTIALS=""
# Or inline JSON key:
# GCP_SERVICE_ACCOUNT_KEY=""

# Optional: default API keys (users can also store their own)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
ELEVENLABS_API_KEY=""
STABILITY_API_KEY=""
GEMINI_API_KEY=""

# Encryption key for user API keys stored in DB (32 hex chars)
API_KEY_ENCRYPTION_SECRET="__GENERATED__"

# CORS origin: "true" to allow any origin (dev), URL string, or comma-separated URLs
CORS_ORIGIN=true

# ─── Production-only (Cloud Run) ──────────────────────────────────────────────
# These are set by cloudbuild.yaml at deploy time. Listed here for documentation.
# In dev they stay empty/unset and post-scene work runs inline.

# GCP project + region — region MUST match Cloud Run service region (europe-west1)
# GCP_PROJECT_ID=""
# GCP_REGION="europe-west1"

# Cloud Tasks: true → enqueue post-scene work via Cloud Tasks; false → inline fire-and-forget
# CLOUD_TASKS_ENABLED=false

# Cloud Run service URL (for Cloud Tasks callback target + OIDC audience).
# After first deploy: gcloud run services describe rage-player-game --region europe-west1 --format 'value(status.url)'
# SELF_URL=""

# Service account that signs OIDC tokens for Cloud Tasks → Cloud Run callbacks.
# Provisioned by cloudbuild.yaml — same SA Cloud Run runs as.
# RUNTIME_SERVICE_ACCOUNT=""
