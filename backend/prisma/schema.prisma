// ═══════════════════════════════════════════════════════════════════════
// Living World — canonical world state shared across campaigns.
// ═══════════════════════════════════════════════════════════════════════

model WorldLocation {
  id                 String       @id @default(uuid(7)) @db.Uuid
  canonicalName      String       @unique
  displayName        String?
  description        String       @default("")
  category           String       @default("generic")
  region             String?
  parentLocationId   String?      @db.Uuid
  locationType       LocationType @default(generic)
  slotType           String?
  slotKind           String       @default("custom")
  maxKeyNpcs         Int          @default(10)
  maxSubLocations    Int          @default(5)
  regionX            Float        @default(0)
  regionY            Float        @default(0)
  positionConfidence Float        @default(0.5)
  subGridX           Int?
  subGridY           Int?
  knownByDefault     Boolean      @default(false)
  dangerLevel        DangerLevel  @default(safe)

  // Entity registry lifecycle — existing rows backfilled as globally active.
  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid

  aliases        Json    @default("[]")
  roomMetadata   Json?
  tags           Json    @default("[]")
  atmosphere     String?
  narrativeRoles Json    @default("[]")
  scale          Int     @default(5)
  nodeShape      String?
  nodeIcon       String?
  nodeImageUrl   String?

  // Faza 0 — graf jako jedyne źródło prawdy o lokacjach.
  // tacticalGrid: 12×12 (lub inny WxH) tile grid do walki; tiles[y][x] = 'P'|'F'|'W'|'D'|'S'.
  // anchorType: explicit override mapowania na sceneAnchors (tavern|forest|dungeon|...).
  // biome: po wywaleniu fieldMap zachowuje semantykę biomu.
  // visitCount + npcsEncountered + modificationsLog: replace world.knowledgeBase.locations[].
  // dungeonState: per-room flags (entryCleared, trapSprung, lootTaken).
  // liberatedAt: timestamp gdy locationLiberated boolean ustawiony przez AI promotion.
  tacticalGrid     Json?
  biome            String?
  anchorType       String?
  visitCount       Int       @default(0)
  npcsEncountered  Json      @default("[]")
  modificationsLog Json      @default("[]")
  dungeonState     Json?
  liberatedAt      DateTime? @db.Timestamptz

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  parent       WorldLocation?  @relation("subloc", fields: [parentLocationId], references: [id], onDelete: SetNull)
  sublocations WorldLocation[] @relation("subloc")

  outgoingEdges     Road[]                   @relation("fromLoc")
  incomingEdges     Road[]                   @relation("toLoc")
  npcsHere          WorldNPC[]               @relation("npcCurrentLoc")
  npcsHome          WorldNPC[]               @relation("npcHomeLoc")
  knowledgeEntries  WorldLocationKnowledge[]
  userDiscoveries   UserDiscoveredLocation[]
  npcKnownByEntries WorldNpcKnownLocation[]

  @@index([region])
  @@index([parentLocationId])
  @@index([locationType])
  @@index([regionX, regionY])
  @@index([globallyActive, softDeletedAt])
}

// DEPRECATED (Faza 0) — Road jest zaszeregowany do usunięcia w Fazie 8.
// Wszystkie movement-edges migrują do polymorphic `LocationEdge` (category=
// 'movement') przez one-shot dev script `migrate-roads-to-edges.js`. Po
// migracji: travel graph (Dijkstra) operuje na LocationEdge, Road table dropped.
//
// Historical: F5b — renamed from WorldLocationEdge. Roads connect two CANONICAL
// WorldLocations only; campaign-created CampaignLocation rows are off-graph
// (no auto-Road on creation). Travel graph (Dijkstra in travelGraph.js) walks
// Road edges only.
//
// Graph system: `relationType` discriminates edge semantics (road, path, door,
// stairs, tunnel, bridge, portal, secret_path, visible_from, audible_from,
// controlled_by, etc.). Dijkstra filters on MOVEMENT_RELATION_TYPES only.
// `metadata` holds per-type structured data (requirements, perception range,
// faction info, narrative hooks). Legacy `gated`/`gateHint` kept for backward
// compat; new edges use `metadata.requirements` instead.
model Road {
  id             String      @id @default(uuid(7)) @db.Uuid
  fromLocationId String      @db.Uuid
  toLocationId   String      @db.Uuid
  distance       Float
  difficulty     DangerLevel @default(safe)
  terrainType    String      @default("road")
  direction      String?
  gated          Boolean     @default(false)
  gateHint       String?

  // Graph system — rich relation taxonomy
  relationType    String  @default("road")
  bidirectional   Boolean @default(true)
  metadata        Json    @default("{}")
  visibility      String  @default("visible") // visible | hidden | secret | legendary
  risk            String? // none | low | moderate | high | extreme
  travelTime      Float? // minutes (optional, derived from distance/terrain if absent)
  weight          Float? // Dijkstra cost override (default = distance)
  edgeDescription String? @map("description") // "Wąska ścieżka wzdłuż klifu"
  confidence      Float? // 0-1, for rumor-based edges

  createdAt DateTime @default(now()) @db.Timestamptz

  from                WorldLocation           @relation("fromLoc", fields: [fromLocationId], references: [id], onDelete: Cascade)
  to                  WorldLocation           @relation("toLoc", fields: [toLocationId], references: [id], onDelete: Cascade)
  campaignDiscoveries CampaignEdgeDiscovery[]
  userDiscoveries     UserDiscoveredEdge[]

  @@unique([fromLocationId, toLocationId, relationType])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([relationType])
}

// Graph system — per-campaign sandbox edges. CampaignLocation rows are off the
// canonical Road graph by design; CampaignEdge provides rich edges between ANY
// combination of WorldLocation and CampaignLocation nodes within a campaign.
// Uses the same polymorphic kind+id pattern as CampaignDiscoveredLocation.
// Cascades with the campaign. relationType uses the same taxonomy as Road
// (validated app-side via RELATION_TYPES in edgeRelations.js).
model CampaignEdge {
  id              String       @id @default(uuid(7)) @db.Uuid
  campaignId      String       @db.Uuid
  fromKind        String // "world" | "campaign"
  fromId          String       @db.Uuid
  toKind          String // "world" | "campaign"
  toId            String       @db.Uuid
  relationType    String       @default("path")
  bidirectional   Boolean      @default(true)
  distance        Float?
  difficulty      DangerLevel?
  metadata        Json         @default("{}")
  visibility      String       @default("visible") // visible | hidden | secret
  risk            String? // none | low | moderate | high | extreme
  travelTime      Float? // minutes
  edgeDescription String?      @map("description")
  confidence      Float? // 0-1 for rumor-based edges
  createdAt       DateTime     @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, fromKind, fromId, toKind, toId, relationType])
  @@index([campaignId])
  @@index([fromKind, fromId])
  @@index([toKind, toId])
  @@index([relationType])
}

// F5b — per-campaign sandbox location. AI-emitted locations during play go
// here, NOT into WorldLocation (which is reserved for canonical hand-authored
// or admin-promoted rows). Off the canonical Road graph by design — travel
// in/out is by selection, not Dijkstra. Cascades with the campaign — deleted
// when the parent Campaign is deleted, or destructively replaced (relink +
// delete) by promotion to a canonical WorldLocation.
//
// `parentLocationKind`/`parentLocationId` is polymorphic: a CampaignLocation
// sublocation can live inside a canonical city OR another CampaignLocation.
model CampaignLocation {
  id                 String       @id @default(uuid(7)) @db.Uuid
  campaignId         String       @db.Uuid
  name               String
  canonicalSlug      String
  description        String       @default("")
  category           String       @default("generic")
  locationType       LocationType @default(generic)
  region             String?
  aliases            Json         @default("[]")
  regionX            Float        @default(0)
  regionY            Float        @default(0)
  positionConfidence Float        @default(0.5)
  subGridX           Int?
  subGridY           Int?
  parentLocationKind String?
  parentLocationId   String?      @db.Uuid
  maxKeyNpcs         Int          @default(10)
  maxSubLocations    Int          @default(5)
  slotType           String?
  slotKind           String       @default("custom")
  dangerLevel        DangerLevel  @default(safe)
  roomMetadata       Json?
  tags               Json         @default("[]")
  atmosphere         String?
  narrativeRoles     Json         @default("[]")
  scale              Int          @default(5)
  nodeShape          String?
  nodeIcon           String?
  nodeImageUrl       String?

  // Faza 0 — graf jako jedyne źródło prawdy. Kopia pól z WorldLocation
  // by per-campaign sandbox lokacje miały te same możliwości metadane.
  tacticalGrid     Json?
  biome            String?
  anchorType       String?
  visitCount       Int       @default(0)
  npcsEncountered  Json      @default("[]")
  modificationsLog Json      @default("[]")
  dungeonState     Json?
  liberatedAt      DateTime? @db.Timestamptz

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, canonicalSlug])
  @@index([campaignId])
  @@index([regionX, regionY])
  @@index([locationType])
}

// Location Graph — semantic edges between any pair of locations (canonical
// WorldLocation OR per-campaign CampaignLocation). Polymorphic from/to via
// kind+id pairs. Supplements Road (which stays for Dijkstra travel) with
// richer spatial, perception, social, narrative, and temporal relations.
model LocationEdge {
  id             String   @id @default(uuid(7)) @db.Uuid
  fromKind       String
  fromId         String   @db.Uuid
  toKind         String
  toId           String   @db.Uuid
  edgeType       String
  category       String
  bidirectional  Boolean  @default(true)
  weight         Float    @default(1.0)
  metadata       Json     @default("{}")
  discoveryState String   @default("unknown")
  confidence     Float    @default(1.0)
  campaignId     String?  @db.Uuid
  createdBy      String   @default("system")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([fromKind, fromId])
  @@index([toKind, toId])
  @@index([edgeType])
  @@index([category])
  @@index([campaignId])
}

model UserWorldKnowledge {
  userId    String   @id @db.Uuid
  updatedAt DateTime @updatedAt @db.Timestamptz

  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  discoveredLocations UserDiscoveredLocation[]
  discoveredEdges     UserDiscoveredEdge[]
}

model WorldNPC {
  id                    String    @id @default(uuid(7)) @db.Uuid
  canonicalId           String    @unique
  name                  String
  role                  String?
  personality           String?
  alignment             String    @default("neutral")
  alive                 Boolean   @default(true)
  currentLocationId     String?   @db.Uuid
  homeLocationId        String?   @db.Uuid
  pausedAt              DateTime? @db.Timestamptz
  pauseSnapshot         Json?
  companionOfCampaignId String?   @db.Uuid
  companionJoinedAt     DateTime? @db.Timestamptz
  companionLoyalty      Int       @default(50)
  lockedByCampaignId    String?   @db.Uuid
  lockedAt              DateTime? @db.Timestamptz
  lockedSnapshot        Json?

  activeGoal         String?
  goalProgress       Json?
  schedule           Json?
  lastTickAt         DateTime? @db.Timestamptz
  tickIntervalHours  Int       @default(24)
  lastTickSceneIndex Int?
  tickIntervalScenes Int       @default(2)
  goalDeadlineAt     DateTime? @db.Timestamptz
  lastLocationPingAt DateTime? @db.Timestamptz
  category           String    @default("commoner")
  keyNpc             Boolean   @default(true)

  // NPC character card — see CampaignNPC.race/creatureKind/stats.
  race         String?
  creatureKind String?
  level        Int     @default(1)
  stats        Json    @default("{}")
  spriteUrl    String?

  // Stable physical description (PL, ~1 sentence) used as the canonical
  // source for portrait generation and player-facing NPC modals.
  appearance String?
  // Way of speaking (PL, ~1 sentence): dialect, accent, characteristic
  // turns of phrase. Injected into the dialog system prompt; NOT shown
  // in player UI.
  dialect String?

  // Entity registry lifecycle — existing rows backfilled as globally active.
  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  currentLocation  WorldLocation?          @relation("npcCurrentLoc", fields: [currentLocationId], references: [id], onDelete: SetNull)
  homeLocation     WorldLocation?          @relation("npcHomeLoc", fields: [homeLocationId], references: [id], onDelete: SetNull)
  campaignShadows  CampaignNPC[]
  attributions     WorldNpcAttribution[]
  knowledgeEntries WorldNpcKnowledge[]
  dialogTurns      WorldNpcDialogTurn[]
  knownLocations   WorldNpcKnownLocation[]

  @@index([currentLocationId])
  @@index([alive])
  @@index([companionOfCampaignId])
  @@index([lockedByCampaignId])
  @@index([globallyActive, softDeletedAt])
}

model WorldEvent {
  id              BigInt   @id @default(autoincrement())
  worldNpcId      String?  @db.Uuid
  // Legacy — ref tylko do canonical WorldLocation. Po Fazie 4.5 callsite
  // używają composite ref (locationKind+locationId). worldLocationId zostaje
  // dla kompatybilności z istniejącymi indeksami i raportami.
  worldLocationId String?  @db.Uuid
  // Faza 0 — composite ref polymorphic do node grafu (WorldLocation lub
  // CampaignLocation). Używany w nowym pipeline (locationLiberated,
  // dungeonComplete, party meetings).
  locationKind    String?
  locationId      String?  @db.Uuid
  campaignId      String?  @db.Uuid
  userId          String?  @db.Uuid
  eventType       String
  payload         Json     @default("{}")
  visibility      String   @default("campaign")
  gameTime        DateTime @db.Timestamptz
  createdAt       DateTime @default(now()) @db.Timestamptz

  @@index([worldNpcId, createdAt])
  @@index([worldLocationId, createdAt])
  @@index([locationKind, locationId, createdAt])
  @@index([campaignId, createdAt])
  @@index([eventType])
  @@index([eventType, visibility, createdAt])
}

model WorldReputation {
  id              BigInt    @id @default(autoincrement())
  characterId     String    @db.Uuid
  scope           String
  scopeKey        String    @default("")
  score           Int       @default(0)
  reputationLabel String?
  bountyAmount    Int       @default(0)
  bountyIssuer    String?
  vendettaActive  Boolean   @default(false)
  lastIncidentAt  DateTime? @db.Timestamptz
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, scope, scopeKey])
  @@index([characterId])
  @@index([scope, scopeKey, score])
}

model WorldNpcAttribution {
  id               BigInt   @id @default(autoincrement())
  worldNpcId       String   @db.Uuid
  actorCharacterId String   @db.Uuid
  actorCampaignId  String   @db.Uuid
  actionType       String
  justified        Boolean  @default(false)
  judgeConfidence  Float    @default(0)
  judgeReason      String?
  alignmentImpact  String
  visibility       String   @default("campaign")
  gameTime         DateTime @db.Timestamptz
  createdAt        DateTime @default(now()) @db.Timestamptz

  npc      WorldNPC  @relation(fields: [worldNpcId], references: [id], onDelete: Cascade)
  actor    Character @relation(fields: [actorCharacterId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [actorCampaignId], references: [id], onDelete: Cascade)

  @@index([actorCharacterId, createdAt])
  @@index([worldNpcId])
}

// F2 — child table replacing WorldNPC.knowledgeBase JSONB array.
// FIFO-capped at 50 per npcId via plpgsql trigger (see migration SQL).
model WorldNpcKnowledge {
  id          BigInt    @id @default(autoincrement())
  npcId       String    @db.Uuid
  content     String
  source      String
  kind        String
  importance  String?
  confidence  Float?
  similarity  Float?
  sensitivity String?
  addedAt     DateTime  @default(now()) @db.Timestamptz
  learnedAt   DateTime? @db.Timestamptz

  npc WorldNPC @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, addedAt])
}

// F2 — child table replacing WorldNPC.dialogHistory JSONB map.
// FIFO-capped at 50 per (npcId, campaignId) via trigger.
model WorldNpcDialogTurn {
  id          BigInt   @id @default(autoincrement())
  npcId       String   @db.Uuid
  campaignId  String   @db.Uuid
  playerMsg   String
  npcResponse String
  emote       String?
  createdAt   DateTime @default(now()) @db.Timestamptz

  npc      WorldNPC @relation(fields: [npcId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([npcId, campaignId, createdAt])
}

// F2 — child table replacing WorldLocation.knowledgeBase JSONB array.
// FIFO-capped at 50 per locationId via trigger.
model WorldLocationKnowledge {
  id         BigInt   @id @default(autoincrement())
  locationId String   @db.Uuid
  content    String
  source     String
  kind       String
  confidence Float?
  similarity Float?
  addedAt    DateTime @default(now()) @db.Timestamptz

  location WorldLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, addedAt])
}

// F3 — replaces Campaign.{discovered,heardAbout,discoveredSub}LocationIds.
// F5b — `locationKind` discriminates "world" | "campaign". Per-campaign fog-of-war
// holds CampaignLocation rows (the campaign-scoped sandbox); canonical lookups
// land in UserDiscoveredLocation so the player carries that knowledge across
// campaigns. No DB FK — locationId is polymorphic and resolved app-side.
model CampaignDiscoveredLocation {
  campaignId   String         @db.Uuid
  locationKind String
  locationId   String         @db.Uuid
  state        DiscoveryState
  discoveredAt DateTime       @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([campaignId, locationKind, locationId])
  @@index([locationKind, locationId])
  @@index([campaignId, state])
}

// F3 — replaces UserWorldKnowledge.{discovered,heardAbout}LocationIds.
// Account-level fog-of-war for canonical (world-seeded) locations only.
model UserDiscoveredLocation {
  userId       String         @db.Uuid
  locationId   String         @db.Uuid
  state        DiscoveryState
  discoveredAt DateTime       @default(now()) @db.Timestamptz

  userKnowledge UserWorldKnowledge @relation(fields: [userId], references: [userId], onDelete: Cascade)
  location      WorldLocation      @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([userId, locationId])
  @@index([locationId])
  @@index([userId, state])
}

// F3 — replaces UserWorldKnowledge.discoveredEdgeIds. Per-user edge discovery.
model UserDiscoveredEdge {
  userId       String   @db.Uuid
  edgeId       String   @db.Uuid
  discoveredAt DateTime @default(now()) @db.Timestamptz

  userKnowledge UserWorldKnowledge @relation(fields: [userId], references: [userId], onDelete: Cascade)
  edge          Road               @relation(fields: [edgeId], references: [id], onDelete: Cascade)

  @@id([userId, edgeId])
  @@index([edgeId])
}

// F3 — replaces WorldLocationEdge.discoveredByCampaigns.
// Renamed vs plan (was "WorldEdgeDiscovery") because the discovery scope is
// per-campaign, not per-world.
model CampaignEdgeDiscovery {
  edgeId       String   @db.Uuid
  campaignId   String   @db.Uuid
  discoveredAt DateTime @default(now()) @db.Timestamptz

  edge     Road     @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([edgeId, campaignId])
  @@index([campaignId])
}

// F3 — replaces WorldNPC.knownLocationIds. NPC's geographic awareness graph;
// `grantedBy` flags provenance: 'seed' (hand-authored), 'promotion' (post-
// campaign promote), 'dialog' (learned in conversation).
model WorldNpcKnownLocation {
  npcId      String   @db.Uuid
  locationId String   @db.Uuid
  grantedBy  String   @default("seed")
  grantedAt  DateTime @default(now()) @db.Timestamptz

  npc      WorldNPC      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  location WorldLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([npcId, locationId])
  @@index([locationId])
}

// F3 — replaces Character.clearedDungeonIds.
// F5b — `dungeonKind` discriminates "world" | "campaign". Dungeons can be
// canonical (seeded) or campaign-created. No DB FK — dungeonId is polymorphic.
model CharacterClearedDungeon {
  characterId String   @db.Uuid
  dungeonKind String
  dungeonId   String   @db.Uuid
  clearedAt   DateTime @default(now()) @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, dungeonKind, dungeonId])
  @@index([dungeonKind, dungeonId])
}

// F3 — replaces CampaignQuest.prerequisiteQuestIds. Self-join on CampaignQuest.
// `questSide` = the dependent quest, `prereqSide` = the prerequisite that must
// complete first.
model CampaignQuestPrerequisite {
  questId        String @db.Uuid
  prerequisiteId String @db.Uuid

  quest        CampaignQuest @relation("questSide", fields: [questId], references: [id], onDelete: Cascade)
  prerequisite CampaignQuest @relation("prereqSide", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@id([questId, prerequisiteId])
  @@index([prerequisiteId])
}

model WorldLoreSection {
  id        String   @id @default(uuid(7)) @db.Uuid
  slug      String   @unique
  title     String
  content   String   @default("")
  order     Int      @default(0)
  updatedBy String?
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([order])
}

// Round E Phase 9 — unified embedding store for world-scope retrieval.
// F1: switched from Json to native vector(1536). Cosine distance via
// pgvector operator (`<=>`); HNSW index added in migration SQL.
model WorldEntityEmbedding {
  id         BigInt                      @id @default(autoincrement())
  entityType String
  entityId   String
  text       String
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime                    @default(now()) @db.Timestamptz
  updatedAt  DateTime                    @updatedAt @db.Timestamptz

  @@unique([entityType, entityId])
  @@index([entityType])
}

model PendingWorldStateChange {
  id               BigInt       @id @default(autoincrement())
  campaignId       String       @db.Uuid
  idempotencyKey   String
  kind             String
  targetHint       String
  targetEntityId   String?
  targetEntityType String?
  newValue         String
  confidence       Float
  similarity       Float?
  reason           String
  status           ReviewStatus @default(pending)
  reviewedBy       String?      @db.Uuid
  reviewedAt       DateTime?    @db.Timestamptz
  reviewNotes      String?
  createdAt        DateTime     @default(now()) @db.Timestamptz
  updatedAt        DateTime     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, idempotencyKey])
  @@index([status, createdAt])
  @@index([campaignId, status])
}

model NPCPromotionCandidate {
  id                BigInt       @id @default(autoincrement())
  campaignId        String       @db.Uuid
  campaignNpcId     String       @db.Uuid
  name              String
  role              String?
  personality       String?
  stats             Json         @default("{}")
  dialogSample      String?
  smallModelVerdict String?
  status            ReviewStatus @default(pending)
  reviewedBy        String?      @db.Uuid
  reviewedAt        DateTime?    @db.Timestamptz
  reviewNotes       String?
  createdAt         DateTime     @default(now()) @db.Timestamptz
  updatedAt         DateTime     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, campaignNpcId])
  @@index([status, createdAt])
}

// F5b — source is a CampaignLocation today (the only kind of non-canonical
// location after F5b). `sourceLocationKind` exists for symmetry with other
// polymorphic refs and to keep us future-proof if we ever promote canonical
// rows for a different reason. No DB FK — source resolved app-side. After
// destructive promotion the source CampaignLocation row is DELETED, so this
// candidate is moot post-approval (the route deletes it as part of approve).
model LocationPromotionCandidate {
  id                 BigInt       @id @default(autoincrement())
  campaignId         String       @db.Uuid
  sourceLocationKind String       @default("campaign")
  sourceLocationId   String       @db.Uuid
  canonicalName      String
  displayName        String?
  locationType       String?
  region             String?
  description        String?
  stats              Json         @default("{}")
  smallModelVerdict  String?
  status             ReviewStatus @default(pending)
  reviewedBy         String?      @db.Uuid
  reviewedAt         DateTime?    @db.Timestamptz
  reviewNotes        String?
  createdAt          DateTime     @default(now()) @db.Timestamptz
  updatedAt          DateTime     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sourceLocationKind, sourceLocationId])
  @@index([status, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Multiplayer
// ═══════════════════════════════════════════════════════════════════════

model MultiplayerSession {
  id        String   @id @default(uuid(7)) @db.Uuid
  roomCode  String   @unique
  hostId    String   @db.Uuid
  phase     String
  gameState Json
  settings  Json
  updatedAt DateTime @updatedAt @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  host    User                       @relation(fields: [hostId], references: [id])
  players MultiplayerSessionPlayer[]
}

// F1 — replaces MultiplayerSession.players (JSON) + characterIds[] (ObjectId array)
model MultiplayerSessionPlayer {
  sessionId   String   @db.Uuid
  odId        String
  name        String
  characterId String?  @db.Uuid
  userId      String?  @db.Uuid
  isHost      Boolean  @default(false)
  joinedAt    DateTime @default(now()) @db.Timestamptz

  session   MultiplayerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character Character?         @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@id([sessionId, odId])
  @@index([characterId])
}

// ═══════════════════════════════════════════════════════════════════════
// Media / Prefabs / Wanted3D
// ═══════════════════════════════════════════════════════════════════════

model MediaAsset {
  id             String   @id @default(uuid(7)) @db.Uuid
  userId         String   @db.Uuid
  campaignId     String?  @db.Uuid
  key            String   @unique
  type           String
  contentType    String
  size           Int      @default(0)
  backend        String   @default("local")
  path           String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @db.Timestamptz
  lastAccessedAt DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([campaignId])
}

model PrefabAsset {
  id             String   @id @default(uuid(7)) @db.Uuid
  key            String   @unique
  category       String   @default("")
  fileName       String
  contentType    String
  size           Int      @default(0)
  backend        String   @default("local")
  path           String   @unique
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
  lastAccessedAt DateTime @default(now()) @db.Timestamptz

  @@index([category])
  @@index([fileName])
}

model Wanted3D {
  id                String   @id @default(uuid(7)) @db.Uuid
  userId            String   @db.Uuid
  campaignId        String?  @db.Uuid
  objectKey         String   @unique
  entityKind        String   @default("object")
  objectId          String
  objectName        String
  objectType        String
  objectDescription String   @default("")
  sceneId           String   @default("")
  sceneText         String   @default("")
  suggestedModelId  String   @default("")
  suggestedCategory String   @default("")
  suggestedFile     String   @default("")
  matchScore        Int      @default(0)
  alreadyExists     Boolean  @default(false)
  status            String   @default("review")
  requestCount      Int      @default(1)
  firstSeenAt       DateTime @default(now()) @db.Timestamptz
  lastSeenAt        DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@map("3dwanted")
}

// ── Map Studio (dev tool — no auth, pseudo-user) ────────────────────

model TilesetPack {
  id              String   @id @default(uuid(7)) @db.Uuid
  userId          String   @db.Uuid
  name            String
  projectTilesize Int      @default(24)
  scaleAlgo       String   @default("nearest")
  origin          Json     @default("{}")
  traitVocab      Json     @default("{}")
  schemaVersion   Int      @default(1)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  tilesets        Tileset[]
  connectionRules ConnectionRule[]

  @@index([userId])
}

model Tileset {
  id               String   @id @default(uuid(7)) @db.Uuid
  packId           String   @db.Uuid
  name             String
  imageKey         String
  imageWidth       Int      @default(0)
  imageHeight      Int      @default(0)
  nativeTilesize   Int      @default(16)
  regions          Json     @default("[]")
  sliceMode        String   @default("whole")
  atlas            Json     @default("{}")
  renderedVariants Json     @default("{}")
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  pack           TilesetPack     @relation(fields: [packId], references: [id], onDelete: Cascade)
  tiles          Tile[]
  autotileGroups AutotileGroup[]

  @@index([packId])
}

model Tile {
  id              String   @id @default(uuid(7)) @db.Uuid
  tilesetId       String   @db.Uuid
  regionId        String   @default("")
  localId         Int
  col             Int      @default(0)
  row             Int      @default(0)
  nativeSize      Int      @default(16)
  atoms           Json     @default("[]")
  traits          Json     @default("{}")
  tags            Json     @default("[]")
  autotileGroupId String?  @db.Uuid
  autotileRole    String?
  notes           String   @default("")
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  tileset       Tileset        @relation(fields: [tilesetId], references: [id], onDelete: Cascade)
  autotileGroup AutotileGroup? @relation(fields: [autotileGroupId], references: [id], onDelete: SetNull)

  @@unique([tilesetId, localId])
  @@index([tilesetId])
  @@index([autotileGroupId])
}

model AutotileGroup {
  id        String   @id @default(uuid(7)) @db.Uuid
  tilesetId String   @db.Uuid
  regionId  String   @default("")
  name      String
  layout    String   @default("blob_47")
  originCol Int      @default(0)
  originRow Int      @default(0)
  cols      Int?
  rows      Int?
  cells     Json     @default("{}")
  traits    Json     @default("{}")
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tileset Tileset @relation(fields: [tilesetId], references: [id], onDelete: Cascade)
  tiles   Tile[]

  @@index([tilesetId])
}

model ConnectionRule {
  id          String   @id @default(uuid(7)) @db.Uuid
  packId      String   @db.Uuid
  name        String   @default("")
  leftTraits  Json     @default("{}")
  rightTraits Json     @default("{}")
  via         String   @default("autotile_group")
  viaRef      Json     @default("{}")
  priority    Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  pack TilesetPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
}

model MapDoc {
  id              String   @id @default(uuid(7)) @db.Uuid
  userId          String   @db.Uuid
  name            String
  size            Json     @default("[64,64]")
  projectTilesize Int      @default(24)
  packIds         String[] @default([])
  layers          Json     @default("{}")
  collision       String   @default("")
  objects         Json     @default("[]")
  meta            Json     @default("{}")
  campaignId      String?  @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  @@index([userId])
}

model MapActor {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @db.Uuid
  name       String
  appearance Json     @default("{}")
  tags       String[] @default([])
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════
// Topic History — stores seed text + AI-generated topic pairs from the
// campaign creator "ułóż temat z wpisanego tekstu" feature.
// ═══════════════════════════════════════════════════════════════════════

model TopicHistory {
  id             String   @id @default(uuid(7)) @db.Uuid
  userId         String   @db.Uuid
  seedText       String
  generatedTopic String
  genre          String   @default("")
  tone           String   @default("")
  createdAt      DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════
// Server Settings — singleton row for global configuration (admin-only).
// voiceConfig stores per-provider voice pools (ElevenLabs + XTTS).
// sceneModelConfig stores admin-set enablement + per-scene pricing for
// TTS and image providers, surfaced to users in the "Koszt sceny" UI.
// ═══════════════════════════════════════════════════════════════════════

model ServerSettings {
  id               String   @id @default("singleton")
  voiceConfig      Json     @default("{}")
  modelOverrides   Json     @default("{}")
  sceneModelConfig Json     @default("{}")
  fontConfig       Json     @default("{}")
  billingEnabled   Boolean  @default(false)
  updatedAt        DateTime @updatedAt @db.Timestamptz
}

// ═══════════════════════════════════════════════════════════════════════
// LLM call log — every backend AI call is recorded here for the sidebar
// observability panel. Capped per user via periodic cleanup.
// ═══════════════════════════════════════════════════════════════════════

model LlmCallLog {
  id         String    @id @default(uuid(7)) @db.Uuid
  userId     String    @db.Uuid
  type       String
  label      String    @default("")
  provider   String?
  model      String?
  status     String    @default("pending")
  durationMs Int?
  error      String?
  request    Json?
  response   Json?
  startedAt  DateTime  @default(now()) @db.Timestamptz
  finishedAt DateTime? @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════
// System metadata — generic key-value store for infra markers (e.g. seed
// version). One row per key, no relations.
// ═══════════════════════════════════════════════════════════════════════

model SystemMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @db.Timestamptz
}

// ═══════════════════════════════════════════════════════════════════════
// Global spell catalog — player-invented spells visible to all campaigns
// (characters still need to learn them individually).
// ═══════════════════════════════════════════════════════════════════════

model CustomSpell {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String   @unique
  school      String?
  description String?
  icon        String?
  manaCost    Int      @default(2)
  createdById String?  @db.Uuid
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @db.Timestamptz

  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid

  @@index([globallyActive, softDeletedAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Global item definition registry — tracks item definitions born in
// campaigns. Characters hold their own inventory stacks; this table is
// the canonical catalog of "item templates" that the world knows about.
// ═══════════════════════════════════════════════════════════════════════

model WorldItemDefinition {
  id               String    @id @default(uuid(7)) @db.Uuid
  itemKey          String    @unique
  displayName      String
  baseType         String?
  description      String    @default("")
  props            Json      @default("{}")
  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  @@index([globallyActive, softDeletedAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Global spell images — once generated for a spell name, shared across
// all players and campaigns.
// ═══════════════════════════════════════════════════════════════════════

model SpellImage {
  name        String   @id
  imageUrl    String
  imagePrompt String?
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz
}

// ═══════════════════════════════════════════════════════════════════════
// Bulk location-sprite generation jobs — admin-only background pipeline
// that iterates over graph nodes and generates PixelLab sprites for
// those without a nodeImageUrl.
// ═══════════════════════════════════════════════════════════════════════

model LocationSpriteJob {
  id          String   @id @default(uuid(7)) @db.Uuid
  status      String   @default("pending") // pending | running | completed | cancelled | failed
  total       Int      @default(0)
  done        Int      @default(0)
  failed      Int      @default(0)
  concurrency Int      @default(3)
  createdBy   String?  @db.Uuid
  startedAt   DateTime? @db.Timestamptz
  finishedAt  DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  items LocationSpriteJobItem[]

  @@index([status])
}

model LocationSpriteJobItem {
  id           String   @id @default(uuid(7)) @db.Uuid
  jobId        String   @db.Uuid
  job          LocationSpriteJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  nodeKind     String   // world | campaign
  nodeId       String   @db.Uuid
  status       String   @default("pending") // pending | running | done | failed
  attempts     Int      @default(0)
  error        String?
  resultingUrl String?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([jobId, status])
  @@unique([jobId, nodeKind, nodeId])
}
