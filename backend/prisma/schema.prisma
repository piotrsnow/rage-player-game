generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ═══════════════════════════════════════════════════════════════════════
// Enums
// ═══════════════════════════════════════════════════════════════════════

enum DangerLevel {
  safe
  moderate
  dangerous
  deadly
}

enum LocationType {
  generic
  hamlet
  village
  town
  city
  capital
  dungeon
  forest
  wilderness
  mountain
  ruin
  camp
  cave
  interior
  dungeon_room
  campaignPlace
  region
  area
  district
  site
  room
  point
  abstract
}

enum DiscoveryState {
  rumored
  heard_about
  visited
  mapped
}

enum ReviewStatus {
  pending
  approved
  rejected
}

// ═══════════════════════════════════════════════════════════════════════
// User / Auth
// ═══════════════════════════════════════════════════════════════════════

model User {
  id               String   @id @default(uuid(7)) @db.Uuid
  email            String   @unique
  passwordHash     String
  apiKeys          String   @default("{}")
  settings         Json     @default("{}")
  isAdmin          Boolean  @default(false)
  contentLanguage  String   @default("pl")
  credits          Int      @default(200)
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  campaigns           Campaign[]
  characters          Character[]
  mediaAssets         MediaAsset[]
  achievements        Achievement[]
  multiplayerSessions MultiplayerSession[]
  wanted3dEntries     Wanted3D[]
  worldKnowledge      UserWorldKnowledge?
  refreshTokens       RefreshToken[]
  topicHistory        TopicHistory[]
  llmCallLogs         LlmCallLog[]
  incidents           CampaignIncident[]
  customSpells        CustomSpell[]
}

model RefreshToken {
  id               BigInt    @id @default(autoincrement())
  tokenId          String    @unique
  userId           String    @db.Uuid
  deviceInfo       String    @default("")
  createdAt        DateTime  @default(now()) @db.Timestamptz
  expiresAt        DateTime  @db.Timestamptz
  replacedAt       DateTime? @db.Timestamptz
  gracePeriodUntil DateTime? @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Achievement {
  id            String   @id @default(uuid(7)) @db.Uuid
  userId        String   @db.Uuid
  achievementId String
  unlockedAt    DateTime @default(now()) @db.Timestamptz
  campaignId    String?  @db.Uuid
  metadata      Json     @default("{}")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════
// Character
// ═══════════════════════════════════════════════════════════════════════

model Character {
  id      String @id @default(uuid(7)) @db.Uuid
  userId  String @db.Uuid
  name    String
  age     Int    @default(23)
  gender  String @default("")
  species String

  attributes      Json @default("{}")
  wounds          Int  @default(0)
  maxWounds       Int  @default(0)
  bonusMaxWounds  Int  @default(0)
  movement        Int  @default(4)
  characterLevel  Int  @default(1)
  characterXp     Int  @default(0)
  attributePoints Int  @default(0)

  mana   Json @default("{\"current\":0,\"max\":0}")
  spells Json @default("{\"known\":[],\"usageCounts\":{},\"scrolls\":[]}")

  money            Json    @default("{\"gold\":0,\"silver\":0,\"copper\":0}")
  equippedMainHand String?
  equippedOffHand  String?
  equippedArmour   String?

  status             String?
  lockedCampaignId   String?
  lockedCampaignName String?
  lockedLocation     String?
  statuses           Json    @default("[]")
  needs              Json    @default("{\"hunger\":100,\"thirst\":100,\"bladder\":100,\"hygiene\":100,\"rest\":100}")
  activeDungeonState Json?

  backstory           String @default("")
  customAttackPresets Json   @default("[]")

  portraitUrl       String @default("")
  spriteUrl         String?
  chargenAppearance Json?
  spriteSheetUrl    String?
  voiceId           String @default("")
  voiceName         String @default("")
  campaignCount     Int    @default(0)

  badgeSummary   String?
  badgeLegend    String?
  badgeSnark     String?
  badgeUpdatedAt DateTime? @db.Timestamptz
  fame           Int       @default(0)
  infamy         Int       @default(0)
  knownTitles    Json      @default("[]")

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants    CampaignParticipant[]
  mpPlayers       MultiplayerSessionPlayer[]
  npcAttributions NpcAttribution[]
  reputations     WorldReputation[]
  clearedDungeons CharacterClearedDungeon[]
  inventoryItems  CharacterInventoryItem[]
  characterSkills CharacterSkill[]
  skillGains      CharacterSkillGain[]
  materials       CharacterMaterial[]
  favoriteScenes  FavoriteScene[]
  badges          CharacterBadge[]

  @@index([userId])
  @@index([lockedCampaignId])
}

model CharacterBadge {
  id          String    @id @default(uuid(7)) @db.Uuid
  characterId String    @db.Uuid
  campaignId  String?   @db.Uuid
  name        String
  description String    @db.Text
  icon        String    @default("shield")
  color       String?
  imageUrl    String?
  imagePrompt String?
  sceneFrom   Int?
  sceneTo     Int?
  xpAwarded   Int?
  earnedAt    DateTime  @default(now()) @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([characterId, earnedAt])
}

model CharacterSkill {
  characterId String    @db.Uuid
  skillName   String
  level       Int       @default(0)
  xp          Int       @default(0)
  cap         Int       @default(10)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, skillName])
  @@index([characterId, level])
}

model CharacterSkillGain {
  id           String   @id @default(uuid(7)) @db.Uuid
  characterId  String   @db.Uuid
  skillName    String
  xpGained     Int
  oldLevel     Int
  newLevel     Int
  playerAction String?  @db.Text
  narrative    String?  @db.Text
  diceRollInfo Json?
  sceneIndex   Int?
  campaignId   String?  @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, skillName, createdAt])
  @@index([characterId])
}

model CharacterInventoryItem {
  characterId String    @db.Uuid
  itemKey     String
  displayName String
  baseType    String?
  quantity    Int       @default(1)
  props       Json      @default("{}")
  imageUrl    String?
  addedAt     DateTime  @default(now()) @db.Timestamptz
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, itemKey])
  @@index([characterId, addedAt])
}

model CharacterMaterial {
  characterId String    @db.Uuid
  materialKey String
  displayName String
  quantity    Int       @default(0)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, materialKey])
}

// ═══════════════════════════════════════════════════════════════════════
// Campaign
// ═══════════════════════════════════════════════════════════════════════

model Campaign {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @db.Uuid
  name       String   @default("")
  genre      String   @default("")
  tone       String   @default("")
  coreState  Json     @default("{}")
  totalCost  Float    @default(0)
  isPublic   Boolean  @default(false)
  shareToken String?  @unique
  rating     Float    @default(0)
  playCount  Int      @default(0)
  lastSaved  DateTime @default(now()) @db.Timestamptz

  livingWorldEnabled  Boolean @default(false)
  questGraphEnabled   Boolean @default(false)
  worldTimeRatio      Float   @default(24.0)
  worldTimeMaxGapDays Int     @default(7)
  difficultyTier      String  @default("low")
  settlementCaps      Json?

  boundsMinX Float?
  boundsMaxX Float?
  boundsMinY Float?
  boundsMaxY Float?

  // DEPRECATED (Faza 3a) — flavor name fallback.
  currentLocationName String?

  // Plain FK to unified Location table (no more kind+id pair).
  currentLocationId String? @db.Uuid

  // Continuous world position for off-location wandering.
  currentX Float?
  currentY Float?

  pendingSlip            String?
  pendingProvidence      Json?
  pendingStateCorrection Json?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentLocation             Location?                    @relation("campaignCurrentLoc", fields: [currentLocationId], references: [id], onDelete: SetNull)
  participants                CampaignParticipant[]
  scenes                      CampaignScene[]
  npcs                        Npc[]                        @relation("npcCampaign")
  knowledge                   CampaignKnowledge[]
  codex                       CampaignCodex[]
  quests                      CampaignQuest[]
  locationSummaries           CampaignLocationSummary[]
  dmAgent                     CampaignDmAgent?
  npcAttributions             NpcAttribution[]
  pendingWorldStateChanges    PendingWorldStateChange[]
  npcPromotionCandidates      NPCPromotionCandidate[]
  locationPromotionCandidates LocationPromotionCandidate[]
  achievements                Achievement[]
  npcDialogTurns              NpcDialogTurn[]
  discoveredLocations         DiscoveredLocation[]
  edgeDiscoveries             CampaignEdgeDiscovery[]
  locations                   Location[]                   @relation("locationCampaign")
  locationEdges               LocationEdge[]
  campaignEdges               CampaignEdge[]
  favoriteScenes              FavoriteScene[]
  characterBadges             CharacterBadge[]
  quickBeats                  CampaignQuickBeat[]
  needsCommentaries           CampaignNeedsCommentary[]
  incidents                   CampaignIncident[]
  snapshots                   CampaignSnapshot[]
  multiplayerSessions         MultiplayerSession[]

  @@index([userId])
  @@index([isPublic])
}

model CampaignParticipant {
  campaignId  String   @db.Uuid
  characterId String   @db.Uuid
  role        String   @default("player")
  joinedAt    DateTime @default(now()) @db.Timestamptz

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([campaignId, characterId])
  @@index([characterId])
}

// ═══════════════════════════════════════════════════════════════════════
// Campaign-scoped entities (scenes, quests, knowledge, codex, DM agent)
// ═══════════════════════════════════════════════════════════════════════

model CampaignScene {
  id               String                       @id @default(uuid(7)) @db.Uuid
  campaignId       String                       @db.Uuid
  sceneIndex       Int
  narrative        String
  chosenAction     String?
  suggestedActions Json                         @default("[]")
  dialogueSegments Json                         @default("[]")
  imagePrompt      String?
  fullImagePrompt  String?
  imageUrl         String?
  soundEffect      String?
  diceRoll         Json?
  stateChanges     Json?
  scenePacing      String?
  embeddingText    String?
  embedding        Unsupported("vector(1536)")?
  generationDurationMs Int?
  responseSizeBytes    Int?
  fieldMapTiles        Json?
  createdAt        DateTime                     @default(now()) @db.Timestamptz

  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  favoritedBy FavoriteScene[]

  @@unique([campaignId, sceneIndex])
  @@index([campaignId, sceneIndex])
}

model CampaignQuickBeat {
  id               String   @id @default(uuid(7)) @db.Uuid
  campaignId       String   @db.Uuid
  parentSceneIndex Int
  characterId      String?  @db.Uuid
  playerAction     String   @db.Text
  narrationText    String   @db.Text
  npcSpeaker       String?
  npcReply         String?  @db.Text
  timeAdvance      Float?
  newItems         Json?
  createdAt        DateTime @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([campaignId, parentSceneIndex])
}

model CampaignNeedsCommentary {
  id             String   @id @default(uuid(7)) @db.Uuid
  campaignId     String   @db.Uuid
  sceneIndex     Int
  characterId    String?  @db.Uuid
  needsSnapshot  Json
  commentaryText String   @db.Text
  createdAt      DateTime @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

model FavoriteScene {
  id          String   @id @default(uuid(7)) @db.Uuid
  characterId String   @db.Uuid
  sceneId     String   @db.Uuid
  campaignId  String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz

  character Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  scene     CampaignScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  campaign  Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([characterId, sceneId])
  @@index([characterId, createdAt(sort: Desc)])
}

model CampaignIncident {
  id               String   @id @default(uuid(7)) @db.Uuid
  campaignId       String   @db.Uuid
  userId           String   @db.Uuid
  sceneIndex       Int
  playerComplaint  String   @db.Text
  aiVerdict        String   @db.Text
  isPlayerRight    Boolean
  technicalDetails       String?  @db.Text
  corrections            Json?
  narrativeComment       String?  @db.Text
  worldCorrectionApplied Boolean?
  createdAt              DateTime @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId, sceneIndex])
  @@index([userId])
}

model CampaignSnapshot {
  id         String   @id @default(uuid(7)) @db.Uuid
  campaignId String   @db.Uuid
  createdBy  String   @db.Uuid
  reason     String?
  pinned     Boolean  @default(false)
  payload    Json
  createdAt  DateTime @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

model CampaignKnowledge {
  id            String                       @id @default(uuid(7)) @db.Uuid
  campaignId    String                       @db.Uuid
  entryType     String
  summary       String
  content       Json
  tags          Json                         @default("[]")
  importance    String?
  status        String?
  sceneIndex    Int?
  embeddingText String?
  embedding     Unsupported("vector(1536)")?
  createdAt     DateTime                     @default(now()) @db.Timestamptz
  updatedAt     DateTime                     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, entryType])
}

// ═══════════════════════════════════════════════════════════════════════
// NPC — unified table (replaces WorldNPC + CampaignNPC).
//
// Scope discriminator:
//   campaignId IS NULL  → canonical (world-level, globally visible)
//   campaignId = <uuid> → scoped to one campaign
//
// Campaign shadows link back to their canonical source via canonicalNpcId.
// AI-created mid-play NPCs have campaignId set but canonicalNpcId = null.
// Promotion = UPDATE SET campaignId = NULL, assign canonicalId.
// ═══════════════════════════════════════════════════════════════════════

model Npc {
  id         String  @id @default(uuid(7)) @db.Uuid
  // NULL = canonical (world); set = campaign-scoped
  campaignId String? @db.Uuid
  // Human-readable slug for canonical NPCs (unique among canonicals)
  canonicalId String?
  // For campaign shadows: FK to the canonical NPC this row is a shadow of
  canonicalNpcId String? @db.Uuid
  // Legacy npcId field (campaign-scoped identifier within a campaign)
  npcId      String?

  name                  String
  gender                String    @default("unknown")
  role                  String?
  personality           String?
  // 'attitude' for campaign-scoped, 'alignment' for canonical
  alignment             String    @default("neutral")
  alive                 Boolean   @default(true)
  disposition           Int       @default(0)
  category              String    @default("commoner")
  factionId             String?
  notes                 String?

  // Location — plain FK to unified Location table
  currentLocationId     String?   @db.Uuid
  homeLocationId        String?   @db.Uuid
  // DEPRECATED — flavor name fallback (to be removed)
  lastLocation          String?

  // Agent / tick state (canonical only)
  isAgent               Boolean   @default(false)
  activeGoal            String?
  goalProgress          Json?
  schedule              Json?
  lastTickAt            DateTime? @db.Timestamptz
  tickIntervalHours     Int       @default(24)
  lastTickSceneIndex    Int?
  tickIntervalScenes    Int       @default(2)
  goalDeadlineAt        DateTime? @db.Timestamptz
  lastLocationPingAt    DateTime? @db.Timestamptz
  keyNpc                Boolean   @default(true)

  // Companion state (canonical only)
  pausedAt              DateTime? @db.Timestamptz
  pauseSnapshot         Json?
  companionOfCampaignId String?   @db.Uuid
  companionJoinedAt     DateTime? @db.Timestamptz
  companionLoyalty      Int       @default(50)
  lockedByCampaignId    String?   @db.Uuid
  lockedAt              DateTime? @db.Timestamptz
  lockedSnapshot        Json?

  // Campaign-specific interaction tracking
  pendingIntroHint          String?
  hasAcknowledgedFame       Boolean   @default(false)
  interactionCount          Int       @default(0)
  dialogCharCount           Int       @default(0)
  questInvolvementCount     Int       @default(0)
  lastInteractionAt         DateTime? @db.Timestamptz
  lastInteractionSceneIndex Int?

  // Character card
  race         String?
  creatureKind String?
  level        Int     @default(1)
  stats        Json    @default("{}")
  portraitUrl       String?
  spriteUrl         String?
  chargenAppearance Json?
  spriteSheetUrl    String?
  appearance        String?
  dialect           String?

  // Entity registry lifecycle
  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  campaign        Campaign?          @relation("npcCampaign", fields: [campaignId], references: [id], onDelete: Cascade)
  canonicalNpc    Npc?               @relation("npcShadow", fields: [canonicalNpcId], references: [id], onDelete: SetNull)
  shadows         Npc[]              @relation("npcShadow")
  currentLocation Location?          @relation("npcCurrentLoc", fields: [currentLocationId], references: [id], onDelete: SetNull)
  homeLocation    Location?          @relation("npcHomeLoc", fields: [homeLocationId], references: [id], onDelete: SetNull)
  attributions    NpcAttribution[]
  knowledgeEntries NpcKnowledge[]
  dialogTurns     NpcDialogTurn[]
  knownLocations  NpcKnownLocation[]
  experiences     NpcExperience[]
  relationships   NpcRelationship[]
  locationMoves   NpcLocationMovement[]
  promotionCandidates NPCPromotionCandidate[]

  @@unique([canonicalId])
  @@unique([campaignId, npcId])
  @@index([campaignId])
  @@index([canonicalNpcId])
  @@index([campaignId, canonicalNpcId])
  @@index([currentLocationId])
  @@index([alive])
  @@index([companionOfCampaignId])
  @@index([lockedByCampaignId])
  @@index([globallyActive, softDeletedAt])
}

// NPC memory entries (merges WorldNpcKnowledge + CampaignNpcExperience).
// scope: 'baseline' = canonical knowledge, 'campaign' = campaign experience
model NpcKnowledge {
  id          BigInt    @id @default(autoincrement())
  npcId       String    @db.Uuid
  content     String
  source      String
  kind        String
  importance  String?
  confidence  Float?
  similarity  Float?
  sensitivity String?
  sceneIndex  Int?
  addedAt     DateTime  @default(now()) @db.Timestamptz
  learnedAt   DateTime? @db.Timestamptz

  npc Npc @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, addedAt])
}

// NPC experience log (campaign-specific lived experience)
model NpcExperience {
  id         BigInt   @id @default(autoincrement())
  npcId      String   @db.Uuid
  content    String
  importance String?
  sceneIndex Int?
  addedAt    DateTime @default(now()) @db.Timestamptz

  npc Npc @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, addedAt])
}

model NpcRelationship {
  id             BigInt @id @default(autoincrement())
  npcId          String @db.Uuid
  targetType     String
  targetRef      String
  relation       String
  strength       Int    @default(0)
  rippleStrength Int    @default(50)

  npc Npc @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@unique([npcId, targetType, targetRef])
  @@index([npcId])
}

model NpcLocationMovement {
  id         BigInt   @id @default(autoincrement())
  npcId      String   @db.Uuid
  fromId     String?  @db.Uuid
  toId       String   @db.Uuid
  source     String
  sceneIndex Int?
  movedAt    DateTime @default(now()) @db.Timestamptz

  npc  Npc       @relation(fields: [npcId], references: [id], onDelete: Cascade)
  from Location? @relation("moveFrom", fields: [fromId], references: [id], onDelete: SetNull)
  to   Location  @relation("moveTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([npcId, movedAt(sort: Desc)])
}

model NpcDialogTurn {
  id          BigInt   @id @default(autoincrement())
  npcId       String   @db.Uuid
  campaignId  String   @db.Uuid
  playerMsg   String
  npcResponse String
  emote       String?
  createdAt   DateTime @default(now()) @db.Timestamptz

  npc      Npc      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([npcId, campaignId, createdAt])
}

model NpcAttribution {
  id               BigInt   @id @default(autoincrement())
  npcId            String   @db.Uuid
  actorCharacterId String   @db.Uuid
  actorCampaignId  String   @db.Uuid
  actionType       String
  justified        Boolean  @default(false)
  justificationRaw String?
  sceneIndex       Int?
  createdAt        DateTime @default(now()) @db.Timestamptz

  npc       Npc       @relation(fields: [npcId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [actorCharacterId], references: [id], onDelete: Cascade)
  campaign  Campaign  @relation(fields: [actorCampaignId], references: [id], onDelete: Cascade)

  @@unique([npcId, actorCharacterId, actorCampaignId, actionType])
  @@index([npcId, createdAt])
  @@index([actorCharacterId])
  @@index([actorCampaignId])
}

model NpcKnownLocation {
  npcId      String   @db.Uuid
  locationId String   @db.Uuid
  grantedBy  String   @default("seed")
  grantedAt  DateTime @default(now()) @db.Timestamptz

  npc      Npc      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([npcId, locationId])
  @@index([locationId])
}

model CampaignCodex {
  id             String                       @id @default(uuid(7)) @db.Uuid
  campaignId     String                       @db.Uuid
  codexKey       String
  name           String
  category       String
  tags           Json                         @default("[]")
  fragments      Json
  relatedEntries Json                         @default("[]")
  embeddingText  String?
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime                     @default(now()) @db.Timestamptz
  updatedAt      DateTime                     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, codexKey])
  @@index([campaignId])
}

model CampaignQuest {
  id                  String    @id @default(uuid(7)) @db.Uuid
  campaignId          String    @db.Uuid
  questId             String
  name                String
  type                String    @default("side")
  description         String    @default("")
  completionCondition String?
  questGiverId        String?
  turnInNpcId         String?
  // Plain FK to Location (no more kind+id)
  locationId          String?   @db.Uuid
  reward              Json?
  status              String    @default("active")
  completedAt         DateTime? @db.Timestamptz
  forcedGiver         Boolean   @default(false)
  mutationLog         Json      @default("[]")
  createdAt           DateTime  @default(now()) @db.Timestamptz
  updatedAt           DateTime  @updatedAt @db.Timestamptz

  campaign        Campaign                    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location        Location?                   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  prerequisites   CampaignQuestPrerequisite[] @relation("questSide")
  prerequisiteFor CampaignQuestPrerequisite[] @relation("prereqSide")
  objectives      CampaignQuestObjective[]

  @@unique([campaignId, questId])
  @@index([campaignId])
  @@index([campaignId, status])
}

model CampaignQuestObjective {
