generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  apiKeys      String   @default("{}") // Encrypted JSON: { openai, anthropic, elevenlabs, stability }
  settings     String   @default("{}") // JSON blob matching frontend settings shape
  isAdmin      Boolean  @default(false) // Phase 6 — admin dashboard access (Living World observability)
  // Phase 7 — Language lock for AI-generated content (NPC names, locations, dialog).
  // UI language (i18next) changes independently via settings.
  contentLanguage String @default("pl") // pl|en
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns             Campaign[]
  characters            Character[]
  mediaAssets           MediaAsset[]
  achievements          Achievement[]
  multiplayerSessions   MultiplayerSession[]
  wanted3dEntries       Wanted3D[]
}

model RefreshToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tokenId    String   @unique
  userId     String   @db.ObjectId
  deviceInfo String   @default("")
  createdAt  DateTime @default(now())
  expiresAt  DateTime                   // TTL index target (expireAfterSeconds: 0)

  @@index([userId])
}

model Achievement {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  achievementId  String   // Frontend achievement key e.g. "first_campaign"
  unlockedAt     DateTime @default(now())
  campaignId     String?  @db.ObjectId
  metadata       String   @default("{}") // JSON: extra context about unlock

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Campaign {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  name           String   @default("")
  genre          String   @default("")
  tone           String   @default("")
  coreState      String   @default("{}") // Lean state: combat, world basics (minus npcs/knowledge/quests/character)
  characterIds   String[] @db.ObjectId   // Character record IDs participating in this campaign (1 in single-player, N in MP)
  totalCost      Float    @default(0)
  isPublic       Boolean  @default(false)
  shareToken     String?  @unique
  rating         Float    @default(0)
  playCount      Int      @default(0)
  lastSaved      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Living World (Phase 1) — experimental flag-gated feature
  livingWorldEnabled  Boolean @default(false)
  worldTimeRatio      Float   @default(24.0) // 1 IRL hour = N game hours
  worldTimeMaxGapDays Int     @default(7)    // cap dla offline gap między wizytami
  // G1 — encounter difficulty cap. Set at creation based on character level:
  //   lv 1-5  → 'low' only
  //   lv 6-10 → low | medium | high
  //   lv 11+  → low | medium | high | deadly
  // Scene systemPrompt and selectBestiaryEncounter both respect this cap so
  // a fresh PC can't be thrown against a dragon unless the player chose it.
  difficultyTier      String  @default("low")
  // Phase A (saturation-biased seeding) — populated by worldSeeder when
  // livingWorldEnabled. JSON strings so shape can evolve without migrations.
  settlementCaps      String? // JSON: { hamlet: n, village: n, town: n, city: n } — capital is global, not tracked here
  worldBounds         String? // JSON: { minX, maxX, minY, maxY } — km, centered on (0,0) so global capital Yeralden is reachable
  // Round A — fog-of-war split. Canonical locations use UserWorldKnowledge
  // (per-user, cross-campaign). Non-canonical (AI-generated mid-play) stay
  // campaign-scoped because the same "Chatka Myśliwego" doesn't exist across
  // parallel playthroughs. `heardAboutLocationIds` is the third fog state
  // (visible on map but drill-down locked). Non-canonical sublocations are
  // tracked separately so parent-location discovery doesn't implicitly expose
  // them.
  discoveredLocationIds    String @default("[]") // JSON array of non-canonical WorldLocation.id
  discoveredSubLocationIds String @default("[]") // JSON array of non-canonical sublocation ids
  heardAboutLocationIds    String @default("[]") // JSON array of non-canonical WorldLocation.id

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
}

model CampaignScene {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId       String   @db.ObjectId
  sceneIndex       Int
  narrative        String
  chosenAction     String?
  suggestedActions String   @default("[]")
  dialogueSegments String   @default("[]")
  imagePrompt      String?
  imageUrl         String?
  soundEffect      String?
  diceRoll         String?
  stateChanges     String?
  scenePacing      String?
  embeddingText    String?
  createdAt        DateTime @default(now())

  @@index([campaignId, sceneIndex])
}

model CampaignKnowledge {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId    String   @db.ObjectId
  entryType     String // "event" | "decision" | "plotThread" | "character" | "location"
  summary       String
  content       String // JSON: full entry data
  tags          String   @default("[]")
  importance    String?
  status        String?
  sceneIndex    Int?
  embeddingText String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignId, entryType])
}

model CampaignNPC {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId    String   @db.ObjectId
  npcId         String
  name          String
  gender        String   @default("unknown")
  role          String?
  personality   String?
  attitude      String   @default("neutral")
  disposition   Int      @default(0)
  alive         Boolean  @default(true)
  lastLocation  String?
  factionId     String?
  notes         String?
  relationships String   @default("[]")
  embeddingText String?
  // Living World (Phase 1) — link to canonical WorldNPC + agent flag
  worldNpcId    String?  @db.ObjectId
  isAgent       Boolean  @default(false)
  // Round A — broad NPC category. Five starter buckets:
  //   guard | merchant | commoner | priest | adventurer
  // Used by questgiver pickers, dialog flavor, and scene-gen intent hints.
  // Backfilled at clone/promotion time via categorize(role) in questGoalAssigner.
  category      String   @default("commoner")
  // G4 — per-NPC flag so a single renown acknowledgment fires once per
  // (campaign, NPC) pair instead of every reencounter.
  hasAcknowledgedFame Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignId])
  @@index([worldNpcId])
  @@unique([campaignId, npcId])
}

model CampaignCodex {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId     String   @db.ObjectId
  codexKey       String
  name           String
  category       String
  tags           String   @default("[]")
  fragments      String // JSON array of fragments
  relatedEntries String   @default("[]")
  embeddingText  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([campaignId])
  @@unique([campaignId, codexKey])
}

model CampaignQuest {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  campaignId           String    @db.ObjectId
  questId              String
  name                 String
  type                 String    @default("side")
  description          String    @default("")
  completionCondition  String?
  questGiverId         String?
  turnInNpcId          String?
  locationId           String?
  prerequisiteQuestIds String    @default("[]")
  objectives           String    @default("[]")
  reward               String?
  status               String    @default("active") // "active" | "completed"
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([campaignId])
  @@unique([campaignId, questId])
}

model CampaignLocationSummary {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId      String   @db.ObjectId
  locationName    String
  summary         String
  keyNpcs         String   @default("[]") // JSON array of NPC names
  unresolvedHooks String   @default("[]") // JSON array of unresolved plot hooks
  sceneCount      Int      @default(0)
  lastVisitScene  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([campaignId])
  @@unique([campaignId, locationName])
}

model Character {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  name            String
  age             Int      @default(23)
  gender          String   @default("")
  species         String
  // RPGon stats
  attributes      String   @default("{}") // JSON: { sila, inteligencja, charyzma, zrecznosc, wytrzymalosc, szczescie }
  skills          String   @default("{}") // JSON: { "SkillName": { level: N, xp: N }, ... }
  wounds          Int      @default(0)
  maxWounds       Int      @default(0)
  movement        Int      @default(4)
  characterLevel  Int      @default(1)
  characterXp     Int      @default(0)
  attributePoints Int      @default(0)
  // Magic
  mana            String   @default("{\"current\":0,\"max\":0}") // JSON: { current, max }
  spells          String   @default("{\"known\":[],\"usageCounts\":{},\"scrolls\":[]}") // JSON: { known, usageCounts, scrolls }
  // Inventory & equipment
  inventory       String   @default("[]") // JSON array of items (each with optional baseType)
  materialBag     String   @default("[]") // JSON array of crafting materials
  money           String   @default("{\"gold\":0,\"silver\":0,\"copper\":0}") // JSON: { gold, silver, copper }
  equipped        String   @default("{\"mainHand\":null,\"offHand\":null,\"armour\":null}") // JSON: { mainHand, offHand, armour }
  // Status & needs
  status          String?  // "alive" | "dead" | "unconscious" — null == alive
  // Campaign lock — a character belongs to at most one campaign at a time.
  // Cleared on campaign delete; updated when the campaign's currentLocation
  // changes so pickers can decide if the character is in a safe spot to
  // release.
  lockedCampaignId   String?
  lockedCampaignName String?
  lockedLocation     String?
  statuses        String   @default("[]") // JSON array of active statuses
  needs           String   @default("{\"hunger\":100,\"thirst\":100,\"bladder\":100,\"hygiene\":100,\"rest\":100}") // JSON
  // Phase 7 — Dungeons this character has already cleared (once per character).
  // JSON array of WorldLocation.id (top-level dungeon node).
  clearedDungeonIds  String   @default("[]")
  // Phase 7 — Transient per-run dungeon state (roomCleared/trapSprung/lootTaken
  // flags). Flushed to clearedDungeonIds on boss defeat. JSON: { dungeonId, rooms: {...} }
  activeDungeonState String?
  // Narrative
  backstory       String   @default("")
  customAttackPresets String @default("[]") // JSON array of custom attack preset strings
  // Presentation
  portraitUrl     String   @default("")
  voiceId         String   @default("")
  voiceName       String   @default("")
  // Library metadata
  campaignCount   Int      @default(0)
  // Living World — world-wide renown / infamy, aggregated from global
  // WorldEvents (campaign_complete / major_deed / dungeon_cleared etc.).
  // Character stays "grey" until fame or infamy crosses 20; crossing
  // thresholds flips the scene systemPrompt RENOWN suffix on.
  fame            Int      @default(0)
  infamy          Int      @default(0)
  knownTitles     String   @default("[]") // JSON array of unlocked title strings
  // Legacy WFRP fields kept for now (CharacterCreationModal still references some)
  careerData      String   @default("{}")
  characteristics String   @default("{}")
  advances        String   @default("{}")
  xp              Int      @default(0)
  xpSpent         Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MultiplayerSession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  roomCode     String   @unique
  hostId       String   @db.ObjectId
  phase        String
  players      String   // JSON array of player data (without ws). Each entry: { odId, name, characterId, ... }
  characterIds String[] @db.ObjectId   // All Character record IDs participating in this room (parallel to players)
  gameState    String   // JSON: world / scenes / combat — character data is NOT embedded, fetched via characterIds
  settings     String   // JSON room settings
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  host User @relation(fields: [hostId], references: [id])
}

model MediaAsset {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  campaignId     String?  @db.ObjectId
  key            String   @unique // Content-addressable hash key e.g. "images/a1b2c3.png"
  type           String   // "image" | "music" | "sfx" | "tts"
  contentType    String   // MIME type
  size           Int      @default(0)
  backend        String   @default("local") // "local" | "gcp"
  path           String   // Storage path (filesystem path or GCS object name)
  metadata       String   @default("{}") // JSON: generation params for cache lookups
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([campaignId])
}

model PrefabAsset {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  key            String   @unique // Stable shared key, usually matching storage path
  category       String   @default("")
  fileName       String
  contentType    String   // MIME type
  size           Int      @default(0)
  backend        String   @default("local") // "local" | "gcp"
  path           String   @unique // Storage path (filesystem path or GCS object name)
  metadata       String   @default("{}") // JSON: import/sync metadata
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastAccessedAt DateTime @default(now())

  @@index([category])
  @@index([fileName])
}

model Wanted3D {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  campaignId       String?  @db.ObjectId
  objectKey        String   @unique
  entityKind       String   @default("object")
  objectId         String
  objectName       String
  objectType       String
  objectDescription String  @default("")
  sceneId          String   @default("")
  sceneText        String   @default("")
  suggestedModelId String   @default("")
  suggestedCategory String  @default("")
  suggestedFile    String   @default("")
  matchScore       Int      @default(0)
  alreadyExists    Boolean  @default(false)
  status           String   @default("review")
  requestCount     Int      @default(1)
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@map("3dwanted")
}

// ═══════════════════════════════════════════════════════════════════════
// Living World (Phase 1)
// Experimental flag-gated feature. See
// C:\Users\patry\.claude\plans\siemanko-chyba-znowu-nie-lucky-flask.md
// ═══════════════════════════════════════════════════════════════════════

model WorldLocation {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  canonicalName String    @unique
  aliases       String    @default("[]") // JSON array — fuzzy dedupe
  description   String    @default("")
  category      String    @default("generic")
  region        String?
  embeddingText String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // embedding field NOT declared — written via native MongoDB driver (writeEmbedding)

  // Phase 7 — Topology
  // parentLocationId: null = top-level settlement/wilderness; set = sublocation (church in X, tavern in X).
  parentLocationId   String?  @db.ObjectId
  // locationType: hamlet|village|town|city|capital|dungeon|forest|wilderness|interior|dungeon_room
  locationType       String   @default("generic")
  // slotType (sublocations only): tavern|church|blacksmith|market|barracks|... null for top-level
  slotType           String?
  // slotKind: required|optional|custom — classifies how the sublocation fits its parent's template
  slotKind           String   @default("custom")
  // Capacity caps (derived from SETTLEMENT_TEMPLATES on create; admin-tunable)
  maxKeyNpcs         Int      @default(10)
  maxSubLocations    Int      @default(5)
  // Position — 2D coordinates, 1 unit = 1 km (capital at 0,0)
  regionX            Float    @default(0)
  regionY            Float    @default(0)
  positionConfidence Float    @default(0.5)

  // Phase 7 — Dungeon room metadata (only populated for locationType='dungeon_room')
  // JSON: { role: entrance|boss|normal|treasure|puzzle,
  //         trapId, enemyTemplateIds, lootTableId, puzzleId,
  //         flavorSeed, entryCleared, trapSprung, lootTaken }
  roomMetadata       String?

  // Round A — hand-authored canonical seed vs AI-generated campaign-specific.
  // Canonical locations (seedWorld.js) are shared across all campaigns and
  // discovery goes to UserWorldKnowledge. Non-canonical is AI-invented at
  // runtime (chatka myśliwego, sekretna krypta) and stays per-campaign.
  isCanonical           Boolean @default(false)
  // Round A — visibility default. `true` only for the capital; other
  // canonical locations start hidden and become visible as the player
  // visits or hears about them.
  knownByDefault        Boolean @default(false)
  // Round A — danger tier, hand-authored for dungeons/wilderness/ruins.
  // Kept as string enum (safe|moderate|dangerous|deadly) to match edge.difficulty.
  dangerLevel           String  @default("safe")
  // Round A — hand-authored sub-grid coords inside a parent settlement.
  // Only set when parentLocationId is non-null. Grid size scales with the
  // parent's locationType (village 5x5, town 7x7, city/capital 10x10).
  subGridX              Int?
  subGridY              Int?
  // Round A — campaign-of-origin for AI-generated locations. Null for canonical.
  // Kept as audit trail even after post-campaign promotion (Round E).
  createdByCampaignId   String? @db.ObjectId
  // Round A — display name shown to the player. For canonical = canonicalName.
  // For non-canonical = original AI-emitted name without global-unique suffix
  // (canonicalName gets `_{campaignIdShort}` appended to avoid cross-campaign
  // collisions in the global canonical name space).
  displayName           String?

  @@index([region])
  @@index([parentLocationId])
  @@index([locationType])
  @@index([isCanonical, createdByCampaignId])
}

// Phase 7 — Graph connections between WorldLocations.
// `distance` uses the same unit scale as regionX/Y (1 unit = 1 km). Overworld
// edges have `direction` from the 8 cardinal sectors; dungeon corridors use
// N|S|E|W|up|down. `gated` = door/lock/puzzle gating traversal; AI narrates
// via `gateHint` ("requires brass key").
model WorldLocationEdge {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  fromLocationId        String   @db.ObjectId
  toLocationId          String   @db.ObjectId
  distance              Float    // km (overworld) or 1 unit per corridor (dungeon)
  difficulty            String   @default("safe") // safe|moderate|dangerous|deadly
  terrainType           String   @default("road") // road|path|wilderness|river|mountain|dungeon_corridor
  direction             String?  // N|NE|E|SE|S|SW|W|NW|up|down — null allowed for abstract edges
  gated                 Boolean  @default(false)
  gateHint              String?  // narrative hint ("requires brass key", "blocked by rubble")
  discoveredByCampaigns String   @default("[]") // JSON array of campaignId — per-campaign visibility
  createdAt             DateTime @default(now())

  @@unique([fromLocationId, toLocationId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

// Phase 7 — Per-user world discovery state. Capital is always implicit.
// Tracks which locations + edges the player has physically reached; used by
// admin map + travel intent to restrict Dijkstra to visible graph.
model UserWorldKnowledge {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String   @unique @db.ObjectId
  discoveredLocationIds String   @default("[]") // JSON array — visited canonical locations
  discoveredEdgeIds     String   @default("[]") // JSON array
  // Round A — "heard-about" third fog state for canonical locations.
  // Entries here render on the map (name visible, dashed outline) but
  // drill-down to sublocations is locked until physical visit promotes
  // the entry to discoveredLocationIds.
  heardAboutLocationIds String   @default("[]")
  updatedAt             DateTime @updatedAt
}

model WorldNPC {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  canonicalId       String    @unique
  name              String
  role              String?
  personality       String?
  alignment         String    @default("neutral") // good|neutral|evil — Phase 3 uses this
  alive             Boolean   @default(true)
  currentLocationId String?   @db.ObjectId
  pausedAt          DateTime?
  pauseSnapshot     String?   // JSON: last activity log + context
  embeddingText     String?
  // Phase 2 — Companion mode
  companionOfCampaignId String?   @db.ObjectId // null = not a companion
  companionJoinedAt     DateTime?
  companionLoyalty      Int       @default(50) // 0-100, drift based on player decisions
  // Phase 2 — Cross-campaign lock (snapshot-and-overlay isolation)
  lockedByCampaignId    String?   @db.ObjectId
  lockedAt              DateTime?
  lockedSnapshot        String?   // JSON: frozen state at joinParty
  // Phase 2 — Per-campaign dialog memory (C2 1-on-1 endpoint)
  dialogHistory         String    @default("{}") // JSON: { campaignId: [{playerMsg, npcResponse, gameTime}] }
  knowledgeBase         String    @default("[]") // JSON: [{ topic, learnedAt, source, sensitivity }]
  // Phase 5 — background ticks (NPC lives when player isn't looking)
  activeGoal             String?   // short sentence describing the NPC's current objective
  goalProgress           String?   // JSON: { step, milestones[], lastAction, lastLocation, updatedAt }
  lastTickAt             DateTime?
  tickIntervalHours      Int       @default(24) // retained for future auto-dispatch (ideas/npc-auto-dispatch)
  // Scene-driven tick cadence (primary mechanism now — see questGoalAssigner)
  lastTickSceneIndex     Int?
  tickIntervalScenes     Int       @default(2)
  // Who this goal is aimed at — resolved at assignment time from the quest's
  // owning campaign. Living World context only surfaces the goal to the
  // campaign whose id matches goalTargetCampaignId (prevents WorldNPC
  // referencing player "Random" in campaign A from leaking into campaign B).
  goalTargetCharacterId  String?   @db.ObjectId
  goalTargetCampaignId   String?   @db.ObjectId
  // "Home" — where the NPC belongs when they have no active task. Set on
  // promotion from their starting location. After a quest concludes, the
  // assigner points the NPC back here (via a return_home goal) instead
  // of leaving them stranded wherever the player last saw them.
  homeLocationId         String?   @db.ObjectId
  // Phase 7 — false = background NPC (no promote, no tick, no agent loop).
  // AI may create background NPCs (generic "Wieśniak") as flavor without
  // filling a key slot. Only keyNpc=true WorldNPCs count against maxKeyNpcs.
  keyNpc                 Boolean   @default(true)
  // Clone-architecture additions (Zakres D).
  // `schedule` holds a JSON {morning, afternoon, evening} of location
  // preferences, used for schedule-driven baseline action resolution
  // without a nano call. `goalDeadlineAt` drives event-driven wakeups —
  // when the current gameTime passes this, the NPC is flagged as due.
  // `lastLocationPingAt` lets globalNpcTriggers throttle
  // first-visit-this-campaign ticks (avoid spam on rapid back-and-forth).
  schedule               String?
  goalDeadlineAt         DateTime?
  lastLocationPingAt     DateTime?
  // Round A — broad NPC category (guard|merchant|commoner|priest|adventurer).
  // Questgiver picker + hearsay policy filter on this. TODO(category-enum):
  // extend with hunter/noble/rogue/scholar/innkeeper/blacksmith when the
  // picker runs out of variety.
  category               String    @default("commoner")
  // Round A — explicit location knowledge. NPCs implicitly know their own
  // location + 1-hop edges (derived at query time). This JSON array holds
  // ADDITIONAL canonical-only locations the NPC is authorized to reveal
  // in dialog (e.g. Kapitan Gerent knows dungeons, Eleya knows wilderness).
  knownLocationIds       String    @default("[]") // JSON array of WorldLocation.id
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // embedding field NOT declared — written via native MongoDB driver (writeEmbedding)

  @@index([currentLocationId])
  @@index([alive])
  @@index([companionOfCampaignId])
  @@index([lockedByCampaignId])
}

model WorldEvent {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  worldNpcId      String?  @db.ObjectId
  worldLocationId String?  @db.ObjectId
  campaignId      String?  @db.ObjectId
  userId          String?  @db.ObjectId
  eventType       String   // moved|spoke|killed|quest_complete|pause_snapshot|resume_summary|...
  payload         String   @default("{}") // JSON
  visibility      String   @default("campaign") // campaign|private (Phase 2 adds "deferred", Phase 3 adds "global")
  gameTime        DateTime
  createdAt       DateTime @default(now())

  @@index([worldNpcId, createdAt])
  @@index([worldLocationId, createdAt])
  @@index([campaignId, createdAt])
  @@index([eventType])
}

// Phase 3 — per-character reputation per scope (global / region / faction / settlement).
// One row per (characterId, scope, scopeKey). `score` in -1000..+1000; `reputationLabel`
// is a computed cached bucket (wanted_criminal .. hero). Bounty/vendetta fields
// summarize escalation state so encounterEscalator can query a single row.
model WorldReputation {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  characterId     String    @db.ObjectId
  scope           String    // "global" | "region" | "faction" | "settlement"
  scopeKey        String    // "" for global; region/faction/settlement id or canonical name
  score           Int       @default(0)
  reputationLabel String?   // wanted_criminal | outlaw | suspicious | neutral | respected | hero
  bountyAmount    Int       @default(0) // in SK (srebrne korony)
  bountyIssuer    String?
  vendettaActive  Boolean   @default(false)
  lastIncidentAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([characterId, scope, scopeKey])
  @@index([characterId])
  @@index([scope, scopeKey, score])
}

// Phase 4 — per-campaign DM agent state. `dmMemory` rolls up what the DM
// planned/introduced/is waiting to resolve; `pendingHooks` is a list of
// quest ideas / intrigue seeds the DM agent wants to weave in later.
// Injected into scene-gen system prompt (conditional on livingWorldEnabled)
// so premium model stays coherent across scenes without re-reading history.
model CampaignDmAgent {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId    String   @unique @db.ObjectId
  dmMemory      String   @default("[]") // JSON: [{at, plannedFor, status, summary}]
  pendingHooks  String   @default("[]") // JSON: [{id, kind, summary, idealTiming, priority}]
  lastUpdatedAt DateTime @default(now())
}

// Phase 3 — append-only ledger of actor-against-NPC actions.
// One row per kill/rob/save/help. `justified` is populated by nano judge.
// `alignmentImpact` = victim's alignment at time of action (good/neutral/evil).
// Visibility governs cross-user injection (Phase 3 cross-user ships later — see
// knowledge/ideas/living-world-cross-user-visibility.md).
model WorldNpcAttribution {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  worldNpcId       String   @db.ObjectId
  actorCharacterId String   @db.ObjectId
  actorCampaignId  String   @db.ObjectId
  actionType       String   // killed | robbed | saved | helped | betrayed
  justified        Boolean  @default(false)
  judgeConfidence  Float    @default(0)
  judgeReason      String?
  alignmentImpact  String   // good | neutral | evil (snapshot of victim at action time)
  visibility       String   @default("campaign") // campaign (default now); "global" once cross-user ships
  gameTime         DateTime
  createdAt        DateTime @default(now())

  @@index([actorCharacterId, createdAt])
  @@index([worldNpcId])
}

// Round A — world lore sections. Admin-editable markdown that gets
// concatenated (in `order`) and prepended to scene-gen prompts as
// `[WORLD LORE] ... [/WORLD LORE]`. One canonical pool shared across all
// campaigns — classic seed content lives in `seedWorld.js`, this is the
// additional handcrafted world-context (pantheon details, faction rumors,
// regional lore) that a DM would want the LLM to always know about.
model WorldLoreSection {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  title     String
  content   String   @default("")
  order     Int      @default(0)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}
