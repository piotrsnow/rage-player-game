generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ═══════════════════════════════════════════════════════════════════════
// Enums (F1) — only closed sets that don't churn. attitude / visibility /
// difficultyTier / quest status stay String because they evolve faster
// than migrations.
// ═══════════════════════════════════════════════════════════════════════

enum DangerLevel {
  safe
  moderate
  dangerous
  deadly
}

enum LocationType {
  generic
  hamlet
  village
  town
  city
  capital
  dungeon
  forest
  wilderness
  mountain
  ruin
  camp
  cave
  interior
  dungeon_room
  campaignPlace
}

enum DiscoveryState {
  heard_about
  visited
}

enum ReviewStatus {
  pending
  approved
  rejected
}

// ═══════════════════════════════════════════════════════════════════════
// User / Auth
// ═══════════════════════════════════════════════════════════════════════

model User {
  id              String   @id @default(uuid(7)) @db.Uuid
  email           String   @unique
  passwordHash    String
  apiKeys         String   @default("{}")
  settings        Json     @default("{}")
  isAdmin         Boolean  @default(false)
  contentLanguage String   @default("pl")
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  campaigns           Campaign[]
  characters          Character[]
  mediaAssets         MediaAsset[]
  achievements        Achievement[]
  multiplayerSessions MultiplayerSession[]
  wanted3dEntries     Wanted3D[]
  worldKnowledge      UserWorldKnowledge?
  refreshTokens       RefreshToken[]
}

model RefreshToken {
  id         BigInt   @id @default(autoincrement())
  tokenId    String   @unique
  userId     String   @db.Uuid
  deviceInfo String   @default("")
  createdAt  DateTime @default(now()) @db.Timestamptz
  expiresAt  DateTime @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Achievement {
  id            String   @id @default(uuid(7)) @db.Uuid
  userId        String   @db.Uuid
  achievementId String
  unlockedAt    DateTime @default(now()) @db.Timestamptz
  campaignId    String?  @db.Uuid
  metadata      Json     @default("{}")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════
// Character (F4 — skills/inventory/materials decomposed into child tables;
// equipped slots are itemKey text refs validated app-side, no FK).
// ═══════════════════════════════════════════════════════════════════════

model Character {
  id      String @id @default(uuid(7)) @db.Uuid
  userId  String @db.Uuid
  name    String
  age     Int    @default(23)
  gender  String @default("")
  species String

  attributes      Json @default("{}")
  wounds          Int  @default(0)
  maxWounds       Int  @default(0)
  movement        Int  @default(4)
  characterLevel  Int  @default(1)
  characterXp     Int  @default(0)
  attributePoints Int  @default(0)

  mana   Json @default("{\"current\":0,\"max\":0}")
  spells Json @default("{\"known\":[],\"usageCounts\":{},\"scrolls\":[]}")

  money            Json    @default("{\"gold\":0,\"silver\":0,\"copper\":0}")
  // F4: equipped slot stores itemKey (slugify(name)) referencing
  // CharacterInventoryItem.itemKey. No FK constraint — app-level invariant
  // (cleared on quantity → 0 / DELETE via clearEquippedRefs helper).
  equippedMainHand String?
  equippedOffHand  String?
  equippedArmour   String?

  status             String?
  lockedCampaignId   String?
  lockedCampaignName String?
  lockedLocation     String?
  statuses           Json    @default("[]")
  needs              Json    @default("{\"hunger\":100,\"thirst\":100,\"bladder\":100,\"hygiene\":100,\"rest\":100}")
  activeDungeonState Json?

  backstory           String @default("")
  customAttackPresets Json   @default("[]")

  portraitUrl   String @default("")
  voiceId       String @default("")
  voiceName     String @default("")
  campaignCount Int    @default(0)
  fame          Int    @default(0)
  infamy        Int    @default(0)
  knownTitles   Json   @default("[]")

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants    CampaignParticipant[]
  mpPlayers       MultiplayerSessionPlayer[]
  npcAttributions WorldNpcAttribution[]
  reputations     WorldReputation[]
  clearedDungeons CharacterClearedDungeon[]
  inventoryItems  CharacterInventoryItem[]
  characterSkills CharacterSkill[]
  materials       CharacterMaterial[]

  @@index([userId])
  @@index([lockedCampaignId])
}

// F4 — skills as a child table. Atomic UPDATE xp = xp + delta WHERE
// (characterId, skillName) instead of full-rewrite of a skills JSONB blob.
model CharacterSkill {
  characterId String    @db.Uuid
  skillName   String
  level       Int       @default(0)
  xp          Int       @default(0)
  cap         Int       @default(10)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, skillName])
  @@index([characterId, level])
}

// F4 — inventory keyed by slugify(name). Items with the same name stack
// (quantity-merge); props of the latest write win. See
// shared/domain/itemKeys.js for the slug rules.
model CharacterInventoryItem {
  characterId String    @db.Uuid
  itemKey     String
  displayName String
  baseType    String?
  quantity    Int       @default(1)
  props       Json      @default("{}")
  imageUrl    String?
  addedAt     DateTime  @default(now()) @db.Timestamptz
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, itemKey])
  @@index([characterId, addedAt])
}

// F4 — materialBag as a child table. Same pattern as items; PK is the
// lowercased name (no `props`, no slot semantics).
model CharacterMaterial {
  characterId String    @db.Uuid
  materialKey String
  displayName String
  quantity    Int       @default(0)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, materialKey])
}

// ═══════════════════════════════════════════════════════════════════════
// Campaign (F1 — coreState stays as JSONB monolith; F5 splits hot scalars
// out into columns).
// ═══════════════════════════════════════════════════════════════════════

model Campaign {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @db.Uuid
  name       String   @default("")
  genre      String   @default("")
  tone       String   @default("")
  coreState  Json     @default("{}")
  totalCost  Float    @default(0)
  isPublic   Boolean  @default(false)
  shareToken String?  @unique
  rating     Float    @default(0)
  playCount  Int      @default(0)
  lastSaved  DateTime @default(now()) @db.Timestamptz

  livingWorldEnabled  Boolean @default(false)
  worldTimeRatio      Float   @default(24.0)
  worldTimeMaxGapDays Int     @default(7)
  // low|medium|high|deadly — encounter cap; separate scale from WorldLocation.dangerLevel
  difficultyTier      String  @default("low")
  settlementCaps      Json?

  // F5 — worldBounds JSONB exploded into 4 nullable Float columns. AI/seeder
  // placement guardrail; null on legacy/non-living-world campaigns. Read via
  // unpackWorldBounds(campaign) helper which rebuilds the legacy {minX,maxX,minY,maxY}
  // shape for callsites that share logic with seeders.
  boundsMinX Float?
  boundsMaxX Float?
  boundsMinY Float?
  boundsMaxY Float?

  // F5 — flavor name of the player's current location (AI-emitted free text).
  // Lifted out of coreState.world.currentLocation on save; synthesized back into
  // the FE shape on read via reconstructFromNormalized.
  currentLocationName String?

  // F5b — polymorphic FK to either WorldLocation (canonical) or CampaignLocation
  // (campaign-scoped). `kind` discriminates: "world" | "campaign". No DB FK
  // constraint — resolved app-side via locationRefs.lookupLocationByKindId.
  // Both columns nullable: AI may emit a name we can't resolve (kind=null,id=null,
  // currentLocationName='the inn') and that's fine — flavor name carries.
  currentLocationKind String?
  currentLocationId   String? @db.Uuid

  // Continuous (km-scale) world position for off-location wandering. When
  // anchored at a POI, callers derive (x, y) from currentLocation.regionX/Y.
  // These columns are written only when the player walks off the POI graph
  // (Phase 2 step movement: "1 km na północ"). Null = at currentLocation.
  // 1 unit = 1 km (matches WorldLocation.regionX/Y scale).
  currentX Float?
  currentY Float?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants                CampaignParticipant[]
  scenes                      CampaignScene[]
  npcs                        CampaignNPC[]
  knowledge                   CampaignKnowledge[]
  codex                       CampaignCodex[]
  quests                      CampaignQuest[]
  locationSummaries           CampaignLocationSummary[]
  dmAgent                     CampaignDmAgent?
  npcAttributions             WorldNpcAttribution[]
  pendingWorldStateChanges    PendingWorldStateChange[]
  npcPromotionCandidates      NPCPromotionCandidate[]
  locationPromotionCandidates LocationPromotionCandidate[]
  achievements                Achievement[]
  worldNpcDialogTurns         WorldNpcDialogTurn[]
  discoveredLocations         CampaignDiscoveredLocation[]
  edgeDiscoveries             CampaignEdgeDiscovery[]
  campaignLocations           CampaignLocation[]

  @@index([userId])
  @@index([isPublic])
}

// F1 — replaces Campaign.characterIds[] @db.ObjectId
model CampaignParticipant {
  campaignId  String   @db.Uuid
  characterId String   @db.Uuid
  role        String   @default("player")
  joinedAt    DateTime @default(now()) @db.Timestamptz

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([campaignId, characterId])
  @@index([characterId])
}

// ═══════════════════════════════════════════════════════════════════════
// Campaign-scoped entities (F1 keeps relationships/experienceLog/objectives
// /prerequisiteQuestIds as JSONB; later phases decompose).
// ═══════════════════════════════════════════════════════════════════════

model CampaignScene {
  id               String                       @id @default(uuid(7)) @db.Uuid
  campaignId       String                       @db.Uuid
  sceneIndex       Int
  narrative        String
  chosenAction     String?
  suggestedActions Json                         @default("[]")
  dialogueSegments Json                         @default("[]")
  imagePrompt      String?
  fullImagePrompt  String?
  imageUrl         String?
  soundEffect      String?
  diceRoll         Json?
  stateChanges     Json?
  scenePacing      String?
  embeddingText    String?
  embedding        Unsupported("vector(1536)")?
  createdAt        DateTime                     @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, sceneIndex])
}

model CampaignKnowledge {
  id            String                       @id @default(uuid(7)) @db.Uuid
  campaignId    String                       @db.Uuid
  entryType     String
  summary       String
  content       Json
  tags          Json                         @default("[]")
  importance    String?
  status        String?
  sceneIndex    Int?
  embeddingText String?
  embedding     Unsupported("vector(1536)")?
  createdAt     DateTime                     @default(now()) @db.Timestamptz
  updatedAt     DateTime                     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, entryType])
}

model CampaignNPC {
  id                        String    @id @default(uuid(7)) @db.Uuid
  campaignId                String    @db.Uuid
  npcId                     String
  name                      String
  gender                    String    @default("unknown")
  role                      String?
  personality               String?
  attitude                  String    @default("neutral")
  disposition               Int       @default(0)
  alive                     Boolean   @default(true)
  // F5b — flavor string + polymorphic FK pair (kind+id resolves to either
  // WorldLocation or CampaignLocation). lastLocation stays as a display cache
  // for AI-emitted names that don't resolve to any row.
  lastLocation              String?
  lastLocationKind          String?
  lastLocationId            String?   @db.Uuid
  factionId                 String?
  notes                     String?
  worldNpcId                String?   @db.Uuid
  isAgent                   Boolean   @default(false)
  category                  String    @default("commoner")
  pendingIntroHint          String?
  activeGoal                String?
  goalProgress              Json?
  hasAcknowledgedFame       Boolean   @default(false)
  interactionCount          Int       @default(0)
  dialogCharCount           Int       @default(0)
  questInvolvementCount     Int       @default(0)
  lastInteractionAt         DateTime? @db.Timestamptz
  lastInteractionSceneIndex Int?

  // NPC character card — race is one of NPC_RACES (Human/Dwarf/Halfling/Orc)
  // or null for story creatures (zjawy, sfinksy, demony, ...) which instead
  // carry a free-text creatureKind tag. `stats` holds the full stat sheet
  // emitted by npcCharacterSheet.generateNpcSheet.
  race         String?
  creatureKind String?
  level        Int     @default(1)
  stats        Json    @default("{}")

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  campaign      Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  worldNpc      WorldNPC?                 @relation(fields: [worldNpcId], references: [id], onDelete: SetNull)
  experiences   CampaignNpcExperience[]
  relationships CampaignNpcRelationship[]

  @@unique([campaignId, npcId])
  @@index([campaignId])
  @@index([worldNpcId])
  @@index([campaignId, worldNpcId])
}

// F4 — replaces CampaignNPC.relationships JSONB.
// targetType = "npc" | "character" | "faction"; targetRef is the unique
// reference within that namespace (npc name today, since `npcName` was the
// shape used). Unique on the triple so `relation` updates idempotently.
model CampaignNpcRelationship {
  id            BigInt      @id @default(autoincrement())
  campaignNpcId String      @db.Uuid
  targetType    String
  targetRef     String
  relation      String
  strength      Int         @default(0)
  campaignNpc   CampaignNPC @relation(fields: [campaignNpcId], references: [id], onDelete: Cascade)

  @@unique([campaignNpcId, targetType, targetRef])
  @@index([campaignNpcId])
}

model CampaignCodex {
  id             String                       @id @default(uuid(7)) @db.Uuid
  campaignId     String                       @db.Uuid
  codexKey       String
  name           String
  category       String
  tags           Json                         @default("[]")
  fragments      Json
  relatedEntries Json                         @default("[]")
  embeddingText  String?
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime                     @default(now()) @db.Timestamptz
  updatedAt      DateTime                     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, codexKey])
  @@index([campaignId])
}

model CampaignQuest {
  id                  String    @id @default(uuid(7)) @db.Uuid
  campaignId          String    @db.Uuid
  questId             String
  name                String
  type                String    @default("side")
  description         String    @default("")
  completionCondition String?
  questGiverId        String?
  turnInNpcId         String?
  locationId          String?
  reward              Json?
  status              String    @default("active")
  completedAt         DateTime? @db.Timestamptz
  forcedGiver         Boolean   @default(false)
  createdAt           DateTime  @default(now()) @db.Timestamptz
  updatedAt           DateTime  @updatedAt @db.Timestamptz

  campaign        Campaign                    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prerequisites   CampaignQuestPrerequisite[] @relation("questSide")
  prerequisiteFor CampaignQuestPrerequisite[] @relation("prereqSide")
  objectives      CampaignQuestObjective[]

  @@unique([campaignId, questId])
  @@index([campaignId])
  @@index([campaignId, status])
}

// F4 — replaces CampaignQuest.objectives JSONB. displayOrder is the
// canonical sort key (insertion order from AI). Replace-on-quest-update
// strategy (deleteMany + createMany), same pattern as F3 prerequisites.
model CampaignQuestObjective {
  id           BigInt        @id @default(autoincrement())
  questId      String        @db.Uuid
  displayOrder Int           @default(0)
  description  String
  progress     Int           @default(0)
  targetAmount Int           @default(1)
  status       String        @default("pending")
  // Per-objective JSONB bag for AI-emitted metadata (onComplete triggers,
  // hints, location targets). Read by quest-trigger handlers and surfaced
  // back into the FE shape verbatim.
  metadata     Json          @default("{}")
  quest        CampaignQuest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@index([questId, displayOrder])
}

model CampaignLocationSummary {
  id              String   @id @default(uuid(7)) @db.Uuid
  campaignId      String   @db.Uuid
  locationName    String
  summary         String
  keyNpcs         Json     @default("[]")
  unresolvedHooks Json     @default("[]")
  sceneCount      Int      @default(0)
  lastVisitScene  Int      @default(0)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locationName])
  @@index([campaignId])
}

model CampaignDmAgent {
  campaignId    String   @id @db.Uuid
  lastUpdatedAt DateTime @default(now()) @db.Timestamptz

  campaign           Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  memoryEntries      CampaignDmMemoryEntry[]
  pendingHookEntries CampaignDmPendingHook[]
}

// F2 — child table replacing CampaignNPC.experienceLog JSONB array.
// FIFO-capped at 20 per campaignNpcId via trigger.
model CampaignNpcExperience {
  id            BigInt   @id @default(autoincrement())
  campaignNpcId String   @db.Uuid
  content       String
  importance    String?
  sceneIndex    Int?
  addedAt       DateTime @default(now()) @db.Timestamptz

  campaignNpc CampaignNPC @relation(fields: [campaignNpcId], references: [id], onDelete: Cascade)

  @@index([campaignNpcId, addedAt])
}

// F2 — child table replacing CampaignDmAgent.dmMemory JSONB array.
// FIFO-capped at 20 per campaignId via trigger.
model CampaignDmMemoryEntry {
  id         BigInt   @id @default(autoincrement())
  campaignId String   @db.Uuid
  at         DateTime @default(now()) @db.Timestamptz
  plannedFor String?
  status     String?
  summary    String

  agent CampaignDmAgent @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)

  @@index([campaignId, at])
}

// F2 — child table replacing CampaignDmAgent.pendingHooks JSONB array.
// FIFO-capped at 12 per campaignId via trigger (oldest dropped, NOT lowest priority —
// `clampList` semantics in dmMemoryService.js).
model CampaignDmPendingHook {
  id          String   @id @default(uuid(7)) @db.Uuid
  campaignId  String   @db.Uuid
  kind        String   @default("generic")
  summary     String
  idealTiming String?
  priority    String   @default("normal")
  createdAt   DateTime @default(now()) @db.Timestamptz

  agent CampaignDmAgent @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Living World — canonical world state shared across campaigns.
// ═══════════════════════════════════════════════════════════════════════

model WorldLocation {
  id                 String       @id @default(uuid(7)) @db.Uuid
  canonicalName      String       @unique
  displayName        String?
  description        String       @default("")
  category           String       @default("generic")
  region             String?
  parentLocationId   String?      @db.Uuid
  locationType       LocationType @default(generic)
  slotType           String?
  slotKind           String       @default("custom")
  maxKeyNpcs         Int          @default(10)
  maxSubLocations    Int          @default(5)
  regionX            Float        @default(0)
  regionY            Float        @default(0)
  positionConfidence Float        @default(0.5)
  subGridX           Int?
  subGridY           Int?
  knownByDefault     Boolean      @default(false)
  dangerLevel        DangerLevel  @default(safe)

  aliases      Json  @default("[]")
  roomMetadata Json?

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  parent       WorldLocation?  @relation("subloc", fields: [parentLocationId], references: [id], onDelete: SetNull)
  sublocations WorldLocation[] @relation("subloc")

  outgoingEdges     Road[]                   @relation("fromLoc")
  incomingEdges     Road[]                   @relation("toLoc")
  npcsHere          WorldNPC[]               @relation("npcCurrentLoc")
  npcsHome          WorldNPC[]               @relation("npcHomeLoc")
  knowledgeEntries  WorldLocationKnowledge[]
  userDiscoveries   UserDiscoveredLocation[]
  npcKnownByEntries WorldNpcKnownLocation[]

  @@index([region])
  @@index([parentLocationId])
  @@index([locationType])
  @@index([regionX, regionY])
}

// F5b — renamed from WorldLocationEdge. Roads connect two CANONICAL WorldLocations
// only; campaign-created CampaignLocation rows are off-graph (no auto-Road on
// creation). Travel graph (Dijkstra in travelGraph.js) walks Road edges only.
model Road {
  id             String      @id @default(uuid(7)) @db.Uuid
  fromLocationId String      @db.Uuid
  toLocationId   String      @db.Uuid
  distance       Float
  difficulty     DangerLevel @default(safe)
  terrainType    String      @default("road")
  direction      String?
  gated          Boolean     @default(false)
  gateHint       String?
  createdAt      DateTime    @default(now()) @db.Timestamptz

  from                WorldLocation           @relation("fromLoc", fields: [fromLocationId], references: [id], onDelete: Cascade)
  to                  WorldLocation           @relation("toLoc", fields: [toLocationId], references: [id], onDelete: Cascade)
  campaignDiscoveries CampaignEdgeDiscovery[]
  userDiscoveries     UserDiscoveredEdge[]

  @@unique([fromLocationId, toLocationId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

// F5b — per-campaign sandbox location. AI-emitted locations during play go
// here, NOT into WorldLocation (which is reserved for canonical hand-authored
// or admin-promoted rows). Off the canonical Road graph by design — travel
// in/out is by selection, not Dijkstra. Cascades with the campaign — deleted
// when the parent Campaign is deleted, or destructively replaced (relink +
// delete) by promotion to a canonical WorldLocation.
//
// `parentLocationKind`/`parentLocationId` is polymorphic: a CampaignLocation
// sublocation can live inside a canonical city OR another CampaignLocation.
model CampaignLocation {
  id                 String       @id @default(uuid(7)) @db.Uuid
  campaignId         String       @db.Uuid
  name               String
  canonicalSlug      String
  description        String       @default("")
  category           String       @default("generic")
  locationType       LocationType @default(generic)
  region             String?
  aliases            Json         @default("[]")
  regionX            Float        @default(0)
  regionY            Float        @default(0)
  positionConfidence Float        @default(0.5)
  subGridX           Int?
  subGridY           Int?
  parentLocationKind String?
  parentLocationId   String?      @db.Uuid
  maxKeyNpcs         Int          @default(10)
  maxSubLocations    Int          @default(5)
  slotType           String?
  slotKind           String       @default("custom")
  dangerLevel        DangerLevel  @default(safe)
  roomMetadata       Json?

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, canonicalSlug])
  @@index([campaignId])
  @@index([regionX, regionY])
  @@index([locationType])
}

model UserWorldKnowledge {
  userId    String   @id @db.Uuid
  updatedAt DateTime @updatedAt @db.Timestamptz

  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  discoveredLocations UserDiscoveredLocation[]
  discoveredEdges     UserDiscoveredEdge[]
}

model WorldNPC {
  id                    String    @id @default(uuid(7)) @db.Uuid
  canonicalId           String    @unique
  name                  String
  role                  String?
  personality           String?
  alignment             String    @default("neutral")
  alive                 Boolean   @default(true)
  currentLocationId     String?   @db.Uuid
  homeLocationId        String?   @db.Uuid
  pausedAt              DateTime? @db.Timestamptz
  pauseSnapshot         Json?
  companionOfCampaignId String?   @db.Uuid
  companionJoinedAt     DateTime? @db.Timestamptz
  companionLoyalty      Int       @default(50)
  lockedByCampaignId    String?   @db.Uuid
  lockedAt              DateTime? @db.Timestamptz
  lockedSnapshot        Json?

  activeGoal         String?
  goalProgress       Json?
  schedule           Json?
  lastTickAt         DateTime? @db.Timestamptz
  tickIntervalHours  Int       @default(24)
  lastTickSceneIndex Int?
  tickIntervalScenes Int       @default(2)
  goalDeadlineAt     DateTime? @db.Timestamptz
  lastLocationPingAt DateTime? @db.Timestamptz
  category           String    @default("commoner")
  keyNpc             Boolean   @default(true)

  // NPC character card — see CampaignNPC.race/creatureKind/stats.
  race         String?
  creatureKind String?
  level        Int     @default(1)
  stats        Json    @default("{}")

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  currentLocation  WorldLocation?          @relation("npcCurrentLoc", fields: [currentLocationId], references: [id], onDelete: SetNull)
  homeLocation     WorldLocation?          @relation("npcHomeLoc", fields: [homeLocationId], references: [id], onDelete: SetNull)
  campaignShadows  CampaignNPC[]
  attributions     WorldNpcAttribution[]
  knowledgeEntries WorldNpcKnowledge[]
  dialogTurns      WorldNpcDialogTurn[]
  knownLocations   WorldNpcKnownLocation[]

  @@index([currentLocationId])
  @@index([alive])
  @@index([companionOfCampaignId])
  @@index([lockedByCampaignId])
}

model WorldEvent {
  id              BigInt   @id @default(autoincrement())
  worldNpcId      String?  @db.Uuid
  worldLocationId String?  @db.Uuid
  campaignId      String?  @db.Uuid
  userId          String?  @db.Uuid
  eventType       String
  payload         Json     @default("{}")
  visibility      String   @default("campaign")
  gameTime        DateTime @db.Timestamptz
  createdAt       DateTime @default(now()) @db.Timestamptz

  @@index([worldNpcId, createdAt])
  @@index([worldLocationId, createdAt])
  @@index([campaignId, createdAt])
  @@index([eventType])
  @@index([eventType, visibility, createdAt])
}

model WorldReputation {
  id              BigInt    @id @default(autoincrement())
  characterId     String    @db.Uuid
  scope           String
  scopeKey        String    @default("")
  score           Int       @default(0)
  reputationLabel String?
  bountyAmount    Int       @default(0)
  bountyIssuer    String?
  vendettaActive  Boolean   @default(false)
  lastIncidentAt  DateTime? @db.Timestamptz
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, scope, scopeKey])
  @@index([characterId])
  @@index([scope, scopeKey, score])
}

model WorldNpcAttribution {
  id               BigInt   @id @default(autoincrement())
  worldNpcId       String   @db.Uuid
  actorCharacterId String   @db.Uuid
  actorCampaignId  String   @db.Uuid
  actionType       String
  justified        Boolean  @default(false)
  judgeConfidence  Float    @default(0)
  judgeReason      String?
  alignmentImpact  String
  visibility       String   @default("campaign")
  gameTime         DateTime @db.Timestamptz
  createdAt        DateTime @default(now()) @db.Timestamptz

  npc      WorldNPC  @relation(fields: [worldNpcId], references: [id], onDelete: Cascade)
  actor    Character @relation(fields: [actorCharacterId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [actorCampaignId], references: [id], onDelete: Cascade)

  @@index([actorCharacterId, createdAt])
  @@index([worldNpcId])
}

// F2 — child table replacing WorldNPC.knowledgeBase JSONB array.
// FIFO-capped at 50 per npcId via plpgsql trigger (see migration SQL).
model WorldNpcKnowledge {
  id          BigInt    @id @default(autoincrement())
  npcId       String    @db.Uuid
  content     String
  source      String
  kind        String
  importance  String?
  confidence  Float?
  similarity  Float?
  sensitivity String?
  addedAt     DateTime  @default(now()) @db.Timestamptz
  learnedAt   DateTime? @db.Timestamptz

  npc WorldNPC @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, addedAt])
}

// F2 — child table replacing WorldNPC.dialogHistory JSONB map.
// FIFO-capped at 50 per (npcId, campaignId) via trigger.
model WorldNpcDialogTurn {
  id          BigInt   @id @default(autoincrement())
  npcId       String   @db.Uuid
  campaignId  String   @db.Uuid
  playerMsg   String
  npcResponse String
  emote       String?
  createdAt   DateTime @default(now()) @db.Timestamptz

  npc      WorldNPC @relation(fields: [npcId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([npcId, campaignId, createdAt])
}

// F2 — child table replacing WorldLocation.knowledgeBase JSONB array.
// FIFO-capped at 50 per locationId via trigger.
model WorldLocationKnowledge {
  id         BigInt   @id @default(autoincrement())
  locationId String   @db.Uuid
  content    String
  source     String
  kind       String
  confidence Float?
  similarity Float?
  addedAt    DateTime @default(now()) @db.Timestamptz

  location WorldLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, addedAt])
}

// F3 — replaces Campaign.{discovered,heardAbout,discoveredSub}LocationIds.
// F5b — `locationKind` discriminates "world" | "campaign". Per-campaign fog-of-war
// holds CampaignLocation rows (the campaign-scoped sandbox); canonical lookups
// land in UserDiscoveredLocation so the player carries that knowledge across
// campaigns. No DB FK — locationId is polymorphic and resolved app-side.
model CampaignDiscoveredLocation {
  campaignId   String         @db.Uuid
  locationKind String
  locationId   String         @db.Uuid
  state        DiscoveryState
  discoveredAt DateTime       @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([campaignId, locationKind, locationId])
  @@index([locationKind, locationId])
  @@index([campaignId, state])
}

// F3 — replaces UserWorldKnowledge.{discovered,heardAbout}LocationIds.
// Account-level fog-of-war for canonical (world-seeded) locations only.
model UserDiscoveredLocation {
  userId       String         @db.Uuid
  locationId   String         @db.Uuid
  state        DiscoveryState
  discoveredAt DateTime       @default(now()) @db.Timestamptz

  userKnowledge UserWorldKnowledge @relation(fields: [userId], references: [userId], onDelete: Cascade)
  location      WorldLocation      @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([userId, locationId])
  @@index([locationId])
  @@index([userId, state])
}

// F3 — replaces UserWorldKnowledge.discoveredEdgeIds. Per-user edge discovery.
model UserDiscoveredEdge {
  userId       String   @db.Uuid
  edgeId       String   @db.Uuid
  discoveredAt DateTime @default(now()) @db.Timestamptz

  userKnowledge UserWorldKnowledge @relation(fields: [userId], references: [userId], onDelete: Cascade)
  edge          Road               @relation(fields: [edgeId], references: [id], onDelete: Cascade)

  @@id([userId, edgeId])
  @@index([edgeId])
}

// F3 — replaces WorldLocationEdge.discoveredByCampaigns.
// Renamed vs plan (was "WorldEdgeDiscovery") because the discovery scope is
// per-campaign, not per-world.
model CampaignEdgeDiscovery {
  edgeId       String   @db.Uuid
  campaignId   String   @db.Uuid
  discoveredAt DateTime @default(now()) @db.Timestamptz

  edge     Road     @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([edgeId, campaignId])
  @@index([campaignId])
}

// F3 — replaces WorldNPC.knownLocationIds. NPC's geographic awareness graph;
// `grantedBy` flags provenance: 'seed' (hand-authored), 'promotion' (post-
// campaign promote), 'dialog' (learned in conversation).
model WorldNpcKnownLocation {
  npcId      String   @db.Uuid
  locationId String   @db.Uuid
  grantedBy  String   @default("seed")
  grantedAt  DateTime @default(now()) @db.Timestamptz

  npc      WorldNPC      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  location WorldLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([npcId, locationId])
  @@index([locationId])
}

// F3 — replaces Character.clearedDungeonIds.
// F5b — `dungeonKind` discriminates "world" | "campaign". Dungeons can be
// canonical (seeded) or campaign-created. No DB FK — dungeonId is polymorphic.
model CharacterClearedDungeon {
  characterId String   @db.Uuid
  dungeonKind String
  dungeonId   String   @db.Uuid
  clearedAt   DateTime @default(now()) @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, dungeonKind, dungeonId])
  @@index([dungeonKind, dungeonId])
}

// F3 — replaces CampaignQuest.prerequisiteQuestIds. Self-join on CampaignQuest.
// `questSide` = the dependent quest, `prereqSide` = the prerequisite that must
// complete first.
model CampaignQuestPrerequisite {
  questId        String @db.Uuid
  prerequisiteId String @db.Uuid

  quest        CampaignQuest @relation("questSide", fields: [questId], references: [id], onDelete: Cascade)
  prerequisite CampaignQuest @relation("prereqSide", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@id([questId, prerequisiteId])
  @@index([prerequisiteId])
}

model WorldLoreSection {
  id        String   @id @default(uuid(7)) @db.Uuid
  slug      String   @unique
  title     String
  content   String   @default("")
  order     Int      @default(0)
  updatedBy String?
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([order])
}

// Round E Phase 9 — unified embedding store for world-scope retrieval.
// F1: switched from Json to native vector(1536). Cosine distance via
// pgvector operator (`<=>`); HNSW index added in migration SQL.
model WorldEntityEmbedding {
  id         BigInt                      @id @default(autoincrement())
  entityType String
  entityId   String
  text       String
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime                    @default(now()) @db.Timestamptz
  updatedAt  DateTime                    @updatedAt @db.Timestamptz

  @@unique([entityType, entityId])
  @@index([entityType])
}

model PendingWorldStateChange {
  id               BigInt       @id @default(autoincrement())
  campaignId       String       @db.Uuid
  idempotencyKey   String
  kind             String
  targetHint       String
  targetEntityId   String?
  targetEntityType String?
  newValue         String
  confidence       Float
  similarity       Float?
  reason           String
  status           ReviewStatus @default(pending)
  reviewedBy       String?      @db.Uuid
  reviewedAt       DateTime?    @db.Timestamptz
  reviewNotes      String?
  createdAt        DateTime     @default(now()) @db.Timestamptz
  updatedAt        DateTime     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, idempotencyKey])
  @@index([status, createdAt])
  @@index([campaignId, status])
}

model NPCPromotionCandidate {
  id                BigInt       @id @default(autoincrement())
  campaignId        String       @db.Uuid
  campaignNpcId     String       @db.Uuid
  name              String
  role              String?
  personality       String?
  stats             Json         @default("{}")
  dialogSample      String?
  smallModelVerdict String?
  status            ReviewStatus @default(pending)
  reviewedBy        String?      @db.Uuid
  reviewedAt        DateTime?    @db.Timestamptz
  reviewNotes       String?
  createdAt         DateTime     @default(now()) @db.Timestamptz
  updatedAt         DateTime     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, campaignNpcId])
  @@index([status, createdAt])
}

// F5b — source is a CampaignLocation today (the only kind of non-canonical
// location after F5b). `sourceLocationKind` exists for symmetry with other
// polymorphic refs and to keep us future-proof if we ever promote canonical
// rows for a different reason. No DB FK — source resolved app-side. After
// destructive promotion the source CampaignLocation row is DELETED, so this
// candidate is moot post-approval (the route deletes it as part of approve).
model LocationPromotionCandidate {
  id                 BigInt       @id @default(autoincrement())
  campaignId         String       @db.Uuid
  sourceLocationKind String       @default("campaign")
  sourceLocationId   String       @db.Uuid
  canonicalName      String
  displayName        String?
  locationType       String?
  region             String?
  description        String?
  stats              Json         @default("{}")
  smallModelVerdict  String?
  status             ReviewStatus @default(pending)
  reviewedBy         String?      @db.Uuid
  reviewedAt         DateTime?    @db.Timestamptz
  reviewNotes        String?
  createdAt          DateTime     @default(now()) @db.Timestamptz
  updatedAt          DateTime     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, sourceLocationKind, sourceLocationId])
  @@index([status, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Multiplayer
// ═══════════════════════════════════════════════════════════════════════

model MultiplayerSession {
  id        String   @id @default(uuid(7)) @db.Uuid
  roomCode  String   @unique
  hostId    String   @db.Uuid
  phase     String
  gameState Json
  settings  Json
  updatedAt DateTime @updatedAt @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  host    User                       @relation(fields: [hostId], references: [id])
  players MultiplayerSessionPlayer[]
}

// F1 — replaces MultiplayerSession.players (JSON) + characterIds[] (ObjectId array)
model MultiplayerSessionPlayer {
  sessionId   String   @db.Uuid
  odId        String
  name        String
  characterId String?  @db.Uuid
  userId      String?  @db.Uuid
  isHost      Boolean  @default(false)
  joinedAt    DateTime @default(now()) @db.Timestamptz

  session   MultiplayerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character Character?         @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@id([sessionId, odId])
  @@index([characterId])
}

// ═══════════════════════════════════════════════════════════════════════
// Media / Prefabs / Wanted3D
// ═══════════════════════════════════════════════════════════════════════

model MediaAsset {
  id             String   @id @default(uuid(7)) @db.Uuid
  userId         String   @db.Uuid
  campaignId     String?  @db.Uuid
  key            String   @unique
  type           String
  contentType    String
  size           Int      @default(0)
  backend        String   @default("local")
  path           String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @db.Timestamptz
  lastAccessedAt DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([campaignId])
}

model PrefabAsset {
  id             String   @id @default(uuid(7)) @db.Uuid
  key            String   @unique
  category       String   @default("")
  fileName       String
  contentType    String
  size           Int      @default(0)
  backend        String   @default("local")
  path           String   @unique
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
  lastAccessedAt DateTime @default(now()) @db.Timestamptz

  @@index([category])
  @@index([fileName])
}

model Wanted3D {
  id                String   @id @default(uuid(7)) @db.Uuid
  userId            String   @db.Uuid
  campaignId        String?  @db.Uuid
  objectKey         String   @unique
  entityKind        String   @default("object")
  objectId          String
  objectName        String
  objectType        String
  objectDescription String   @default("")
  sceneId           String   @default("")
  sceneText         String   @default("")
  suggestedModelId  String   @default("")
  suggestedCategory String   @default("")
  suggestedFile     String   @default("")
  matchScore        Int      @default(0)
  alreadyExists     Boolean  @default(false)
  status            String   @default("review")
  requestCount      Int      @default(1)
  firstSeenAt       DateTime @default(now()) @db.Timestamptz
  lastSeenAt        DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@map("3dwanted")
}
