generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ═══════════════════════════════════════════════════════════════════════
// Enums (F1) — only closed sets that don't churn. attitude / visibility /
// difficultyTier / quest status stay String because they evolve faster
// than migrations.
// ═══════════════════════════════════════════════════════════════════════

enum DangerLevel {
  safe
  moderate
  dangerous
  deadly
}

enum LocationType {
  generic
  hamlet
  village
  town
  city
  capital
  dungeon
  forest
  wilderness
  mountain
  ruin
  camp
  cave
  interior
  dungeon_room
  campaignPlace
  // Graph system — finer-grained location scales
  region
  area
  district
  site
  room
  point
  abstract
}

enum DiscoveryState {
  rumored
  heard_about
  visited
  mapped
}

enum ReviewStatus {
  pending
  approved
  rejected
}

// ═══════════════════════════════════════════════════════════════════════
// User / Auth
// ═══════════════════════════════════════════════════════════════════════

model User {
  id               String   @id @default(uuid(7)) @db.Uuid
  email            String   @unique
  passwordHash     String
  apiKeys          String   @default("{}")
  settings         Json     @default("{}")
  isAdmin          Boolean  @default(false)
  contentLanguage  String   @default("pl")
  credits          Int      @default(200)
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  campaigns           Campaign[]
  characters          Character[]
  mediaAssets         MediaAsset[]
  achievements        Achievement[]
  multiplayerSessions MultiplayerSession[]
  wanted3dEntries     Wanted3D[]
  worldKnowledge      UserWorldKnowledge?
  refreshTokens       RefreshToken[]
  topicHistory        TopicHistory[]
  llmCallLogs         LlmCallLog[]
  incidents           CampaignIncident[]
  customSpells        CustomSpell[]
}

model RefreshToken {
  id               BigInt    @id @default(autoincrement())
  tokenId          String    @unique
  userId           String    @db.Uuid
  deviceInfo       String    @default("")
  createdAt        DateTime  @default(now()) @db.Timestamptz
  expiresAt        DateTime  @db.Timestamptz
  replacedAt       DateTime? @db.Timestamptz
  gracePeriodUntil DateTime? @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Achievement {
  id            String   @id @default(uuid(7)) @db.Uuid
  userId        String   @db.Uuid
  achievementId String
  unlockedAt    DateTime @default(now()) @db.Timestamptz
  campaignId    String?  @db.Uuid
  metadata      Json     @default("{}")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════
// Character (F4 — skills/inventory/materials decomposed into child tables;
// equipped slots are itemKey text refs validated app-side, no FK).
// ═══════════════════════════════════════════════════════════════════════

model Character {
  id      String @id @default(uuid(7)) @db.Uuid
  userId  String @db.Uuid
  name    String
  age     Int    @default(23)
  gender  String @default("")
  species String

  attributes      Json @default("{}")
  wounds          Int  @default(0)
  maxWounds       Int  @default(0)
  bonusMaxWounds  Int  @default(0)
  movement        Int  @default(4)
  characterLevel  Int  @default(1)
  characterXp     Int  @default(0)
  attributePoints Int  @default(0)

  mana   Json @default("{\"current\":0,\"max\":0}")
  spells Json @default("{\"known\":[],\"usageCounts\":{},\"scrolls\":[]}")

  money            Json    @default("{\"gold\":0,\"silver\":0,\"copper\":0}")
  // F4: equipped slot stores itemKey (slugify(name)) referencing
  // CharacterInventoryItem.itemKey. No FK constraint — app-level invariant
  // (cleared on quantity → 0 / DELETE via clearEquippedRefs helper).
  equippedMainHand String?
  equippedOffHand  String?
  equippedArmour   String?

  status             String?
  lockedCampaignId   String?
  lockedCampaignName String?
  lockedLocation     String?
  statuses           Json    @default("[]")
  needs              Json    @default("{\"hunger\":100,\"thirst\":100,\"bladder\":100,\"hygiene\":100,\"rest\":100}")
  activeDungeonState Json?

  backstory           String @default("")
  customAttackPresets Json   @default("[]")

  portraitUrl   String @default("")
  spriteUrl     String?
  voiceId       String @default("")
  voiceName     String @default("")
  campaignCount Int    @default(0)

  badgeSummary   String?
  badgeLegend    String?
  badgeSnark     String?
  badgeUpdatedAt DateTime? @db.Timestamptz
  fame           Int       @default(0)
  infamy         Int       @default(0)
  knownTitles    Json      @default("[]")
  skillBadges    Json      @default("[]")

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants    CampaignParticipant[]
  mpPlayers       MultiplayerSessionPlayer[]
  npcAttributions WorldNpcAttribution[]
  reputations     WorldReputation[]
  clearedDungeons CharacterClearedDungeon[]
  inventoryItems  CharacterInventoryItem[]
  characterSkills CharacterSkill[]
  skillGains      CharacterSkillGain[]
  materials       CharacterMaterial[]
  favoriteScenes  FavoriteScene[]

  @@index([userId])
  @@index([lockedCampaignId])
}

// F4 — skills as a child table. Atomic UPDATE xp = xp + delta WHERE
// (characterId, skillName) instead of full-rewrite of a skills JSONB blob.
model CharacterSkill {
  characterId String    @db.Uuid
  skillName   String
  level       Int       @default(0)
  xp          Int       @default(0)
  cap         Int       @default(10)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, skillName])
  @@index([characterId, level])
}

model CharacterSkillGain {
  id           String   @id @default(uuid(7)) @db.Uuid
  characterId  String   @db.Uuid
  skillName    String
  xpGained     Int
  oldLevel     Int
  newLevel     Int
  playerAction String?  @db.Text
  narrative    String?  @db.Text
  diceRollInfo Json?
  sceneIndex   Int?
  campaignId   String?  @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, skillName, createdAt])
  @@index([characterId])
}

// F4 — inventory keyed by slugify(name). Items with the same name stack
// (quantity-merge); props of the latest write win. See
// shared/domain/itemKeys.js for the slug rules.
model CharacterInventoryItem {
  characterId String    @db.Uuid
  itemKey     String
  displayName String
  baseType    String?
  quantity    Int       @default(1)
  props       Json      @default("{}")
  imageUrl    String?
  addedAt     DateTime  @default(now()) @db.Timestamptz
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, itemKey])
  @@index([characterId, addedAt])
}

// F4 — materialBag as a child table. Same pattern as items; PK is the
// lowercased name (no `props`, no slot semantics).
model CharacterMaterial {
  characterId String    @db.Uuid
  materialKey String
  displayName String
  quantity    Int       @default(0)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([characterId, materialKey])
}

// ═══════════════════════════════════════════════════════════════════════
// Campaign (F1 — coreState stays as JSONB monolith; F5 splits hot scalars
// out into columns).
// ═══════════════════════════════════════════════════════════════════════

model Campaign {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @db.Uuid
  name       String   @default("")
  genre      String   @default("")
  tone       String   @default("")
  coreState  Json     @default("{}")
  totalCost  Float    @default(0)
  isPublic   Boolean  @default(false)
  shareToken String?  @unique
  rating     Float    @default(0)
  playCount  Int      @default(0)
  lastSaved  DateTime @default(now()) @db.Timestamptz

  livingWorldEnabled  Boolean @default(false)
  // Branching quest graph + diegetic discovery (oś 1+5). Nowe kampanie
  // dostają true, stare zostają na liniowych questach — opt-in upgrade
  // przez admin endpoint /api/admin/campaigns/:id/upgrade-quest-graph.
  questGraphEnabled   Boolean @default(false)
  worldTimeRatio      Float   @default(24.0)
  worldTimeMaxGapDays Int     @default(7)
  // low|medium|high|deadly — encounter cap; separate scale from WorldLocation.dangerLevel
  difficultyTier      String  @default("low")
  settlementCaps      Json?

  // F5 — worldBounds JSONB exploded into 4 nullable Float columns. AI/seeder
  // placement guardrail; null on legacy/non-living-world campaigns. Read via
  // unpackWorldBounds(campaign) helper which rebuilds the legacy {minX,maxX,minY,maxY}
  // shape for callsites that share logic with seeders.
  boundsMinX Float?
  boundsMaxX Float?
  boundsMinY Float?
  boundsMaxY Float?

  // DEPRECATED (Faza 3a) — flavor name lifted z coreState.world.currentLocation.
  // Faza 0 zachowuje kolumnę aby nie złamać callsite'ów (campaignSerialize,
  // campaignSync, livingWorld, public/crud routes). Usunięcie + cleanup
  // callsite'ów wraz z migracją state na composite ref w Fazie 3a.
  currentLocationName String?

  // Composite ref: `currentLocationKind` + `currentLocationId` (polymorphic
  // FK do WorldLocation lub CampaignLocation). Po Fazie 3a — jedyny ref.
  currentLocationKind String?
  currentLocationId   String? @db.Uuid

  // Continuous (km-scale) world position for off-location wandering. When
  // anchored at a POI, callers derive (x, y) from currentLocation.regionX/Y.
  // These columns are written only when the player walks off the POI graph
  // (Phase 2 step movement: "1 km na północ"). Null = at currentLocation.
  // 1 unit = 1 km (matches WorldLocation.regionX/Y scale).
  currentX Float?
  currentY Float?

  // One-shot narrative injection from incident system. Scene gen reads it,
  // injects into user prompt, then clears it after generation.
  pendingSlip String?

  // One-shot "providence" payload set by the incident route after a positive
  // verdict that produced concrete corrections (correctionSummary non-empty).
  // The next scene generation reads this, weaves a short atmospheric scene
  // where the world reveals/manifests the correction, then clears it.
  // Shape: { summary: string[], narrativeComment: string|null }
  pendingProvidence Json?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user                        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants                CampaignParticipant[]
  scenes                      CampaignScene[]
  npcs                        CampaignNPC[]
  knowledge                   CampaignKnowledge[]
  codex                       CampaignCodex[]
  quests                      CampaignQuest[]
  locationSummaries           CampaignLocationSummary[]
  dmAgent                     CampaignDmAgent?
  npcAttributions             WorldNpcAttribution[]
  pendingWorldStateChanges    PendingWorldStateChange[]
  npcPromotionCandidates      NPCPromotionCandidate[]
  locationPromotionCandidates LocationPromotionCandidate[]
  achievements                Achievement[]
  worldNpcDialogTurns         WorldNpcDialogTurn[]
  discoveredLocations         CampaignDiscoveredLocation[]
  edgeDiscoveries             CampaignEdgeDiscovery[]
  campaignLocations           CampaignLocation[]
  locationEdges               LocationEdge[]
  campaignEdges               CampaignEdge[]
  favoriteScenes              FavoriteScene[]
  quickBeats                  CampaignQuickBeat[]
  incidents                   CampaignIncident[]
  snapshots                   CampaignSnapshot[]

  @@index([userId])
  @@index([isPublic])
}

// F1 — replaces Campaign.characterIds[] @db.ObjectId
model CampaignParticipant {
  campaignId  String   @db.Uuid
  characterId String   @db.Uuid
  role        String   @default("player")
  joinedAt    DateTime @default(now()) @db.Timestamptz

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([campaignId, characterId])
  @@index([characterId])
}

// ═══════════════════════════════════════════════════════════════════════
// Campaign-scoped entities (F1 keeps relationships/experienceLog/objectives
// /prerequisiteQuestIds as JSONB; later phases decompose).
// ═══════════════════════════════════════════════════════════════════════

model CampaignScene {
  id               String                       @id @default(uuid(7)) @db.Uuid
  campaignId       String                       @db.Uuid
  sceneIndex       Int
  narrative        String
  chosenAction     String?
  suggestedActions Json                         @default("[]")
  dialogueSegments Json                         @default("[]")
  imagePrompt      String?
  fullImagePrompt  String?
  imageUrl         String?
  soundEffect      String?
  diceRoll         Json?
  stateChanges     Json?
  scenePacing      String?
  embeddingText    String?
  embedding        Unsupported("vector(1536)")?
  generationDurationMs Int?
  responseSizeBytes    Int?
  createdAt        DateTime                     @default(now()) @db.Timestamptz

  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  favoritedBy FavoriteScene[]

  @@unique([campaignId, sceneIndex])
  @@index([campaignId, sceneIndex])
}

// Lightweight RP-beat that does NOT bump sceneIndex or trigger postSceneWork.
// Used by the "Mała akcja" quick-beat path: nano-generated narration (1-3
// sentences) anchored to the most recent CampaignScene. No imagePrompt,
// no embedding, no stateChanges (only optional timeAdvance applied to
// Character via the standard mutation path). Persisted so the chat history
// survives reload, but invisible to memoryCompressor / vectorSearchService.
model CampaignQuickBeat {
  id               String   @id @default(uuid(7)) @db.Uuid
  campaignId       String   @db.Uuid
  parentSceneIndex Int
  characterId      String?  @db.Uuid
  playerAction     String   @db.Text
  narrationText    String   @db.Text
  npcSpeaker       String?
  npcReply         String?  @db.Text
  timeAdvance      Float?
  createdAt        DateTime @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([campaignId, parentSceneIndex])
}

// Per-character bookmarked scenes. Heart toggle in gameplay UI; surfaced as a
// list in the character panel alongside skill gain history.
model FavoriteScene {
  id          String   @id @default(uuid(7)) @db.Uuid
  characterId String   @db.Uuid
  sceneId     String   @db.Uuid
  campaignId  String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz

  character Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  scene     CampaignScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  campaign  Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([characterId, sceneId])
  @@index([characterId, createdAt(sort: Desc)])
}

model CampaignIncident {
  id               String   @id @default(uuid(7)) @db.Uuid
  campaignId       String   @db.Uuid
  userId           String   @db.Uuid
  sceneIndex       Int
  playerComplaint  String   @db.Text
  aiVerdict        String   @db.Text
  isPlayerRight    Boolean
  technicalDetails       String?  @db.Text
  corrections            Json?
  narrativeComment       String?  @db.Text
  /// When isPlayerRight: true — whether processStateChanges finished without throw (world/campaign side-effects).
  worldCorrectionApplied Boolean?
  createdAt              DateTime @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId, sceneIndex])
  @@index([userId])
}

// Admin panel — point-in-time snapshot of full campaign graph (Campaign + all
// child rows + linked Characters + referenced WorldNPCs/WorldLocations). Created
// automatically before each admin edit, plus manual user-pinned snapshots.
// Restore: deleteMany children → recreate from payload → reconstructFromNormalized.
// FIFO trim to 20 non-pinned per campaign.
model CampaignSnapshot {
  id         String   @id @default(uuid(7)) @db.Uuid
  campaignId String   @db.Uuid
  createdBy  String   @db.Uuid
  reason     String?
  pinned     Boolean  @default(false)
  payload    Json
  createdAt  DateTime @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

model CampaignKnowledge {
  id            String                       @id @default(uuid(7)) @db.Uuid
  campaignId    String                       @db.Uuid
  entryType     String
  summary       String
  content       Json
  tags          Json                         @default("[]")
  importance    String?
  status        String?
  sceneIndex    Int?
  embeddingText String?
  embedding     Unsupported("vector(1536)")?
  createdAt     DateTime                     @default(now()) @db.Timestamptz
  updatedAt     DateTime                     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, entryType])
}

model CampaignNPC {
  id                        String    @id @default(uuid(7)) @db.Uuid
  campaignId                String    @db.Uuid
  npcId                     String
  name                      String
  gender                    String    @default("unknown")
  role                      String?
  personality               String?
  attitude                  String    @default("neutral")
  disposition               Int       @default(0)
  alive                     Boolean   @default(true)
  // DEPRECATED (Faza 3a) — flavor name fallback (npr. AI-emitted "the inn"
  // bez resolved node). Faza 0 zachowuje kolumnę aby nie złamać callsite'ów
  // (campaignSync, intentClassifier/nanoSelector, aiContextTools/handlers/npc).
  // Usunięcie wraz z BE cleanup w Fazie 3a.
  lastLocation              String?
  // Composite ref do grafu (polymorphic). Po Fazie 3a — jedyny ref.
  lastLocationKind          String?
  lastLocationId            String?   @db.Uuid
  factionId                 String?
  notes                     String?
  worldNpcId                String?   @db.Uuid
  isAgent                   Boolean   @default(false)
  category                  String    @default("commoner")
  pendingIntroHint          String?
  activeGoal                String?
  goalProgress              Json?
  hasAcknowledgedFame       Boolean   @default(false)
  interactionCount          Int       @default(0)
  dialogCharCount           Int       @default(0)
  questInvolvementCount     Int       @default(0)
  lastInteractionAt         DateTime? @db.Timestamptz
  lastInteractionSceneIndex Int?

  // NPC character card — race is one of NPC_RACES (Human/Dwarf/Halfling/Orc)
  // or null for story creatures (zjawy, sfinksy, demony, ...) which instead
  // carry a free-text creatureKind tag. `stats` holds the full stat sheet
  // emitted by npcCharacterSheet.generateNpcSheet.
  race         String?
  creatureKind String?
  level        Int     @default(1)
  stats        Json    @default("{}")
  portraitUrl  String?
  spriteUrl    String?

  // Stable physical description (PL, ~1 sentence) used as the canonical
  // source for portrait generation and player-facing NPC modals.
  appearance String?
  // Way of speaking (PL, ~1 sentence): dialect, accent, characteristic
  // turns of phrase. Injected into the dialog system prompt; NOT shown
  // in player UI.
  dialect String?

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  campaign      Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  worldNpc      WorldNPC?                 @relation(fields: [worldNpcId], references: [id], onDelete: SetNull)
  experiences   CampaignNpcExperience[]
  relationships CampaignNpcRelationship[]
  locationMoves CampaignNpcLocationMovement[]

  @@unique([campaignId, npcId])
  @@index([campaignId])
  @@index([worldNpcId])
  @@index([campaignId, worldNpcId])
}

// F4 — replaces CampaignNPC.relationships JSONB.
// targetType = "npc" | "character" | "faction"; targetRef is the unique
// reference within that namespace (npc name today, since `npcName` was the
// shape used). Unique on the triple so `relation` updates idempotently.
model CampaignNpcRelationship {
  id            BigInt      @id @default(autoincrement())
  campaignNpcId String      @db.Uuid
  targetType    String
  targetRef     String
  relation      String
  // strength: -100..+100 — kierunkowa wartość relacji (negatywna = wrogość).
  strength      Int         @default(0)
  // rippleStrength: 0..100 — natężenie z jakim X reaguje na zmiany u target-a
  // (oś 2). Asymmetric: brat może mocno reagować na siostrę (90), a siostra
  // tylko trochę na brata (40). Backfill SQL: LEAST(100, ABS(strength)).
  rippleStrength Int        @default(50)
  campaignNpc   CampaignNPC @relation(fields: [campaignNpcId], references: [id], onDelete: Cascade)

  @@unique([campaignNpcId, targetType, targetRef])
  @@index([campaignNpcId])
}

/// Append-only log of CampaignNPC graph-node location changes for location-graph inspector.
model CampaignNpcLocationMovement {
  id              BigInt   @id @default(autoincrement())
  campaignNpcId   String   @db.Uuid
  fromKind        String?
  fromId          String?  @db.Uuid
  toKind          String
  toId            String   @db.Uuid
  /// scene_process | location_graph_manual
  source          String
  sceneIndex      Int?
  movedAt         DateTime @default(now()) @db.Timestamptz

  campaignNpc CampaignNPC @relation(fields: [campaignNpcId], references: [id], onDelete: Cascade)

  @@index([campaignNpcId, movedAt(sort: Desc)])
}

model CampaignCodex {
  id             String                       @id @default(uuid(7)) @db.Uuid
  campaignId     String                       @db.Uuid
  codexKey       String
  name           String
  category       String
  tags           Json                         @default("[]")
  fragments      Json
  relatedEntries Json                         @default("[]")
  embeddingText  String?
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime                     @default(now()) @db.Timestamptz
  updatedAt      DateTime                     @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, codexKey])
  @@index([campaignId])
}

model CampaignQuest {
  id                  String    @id @default(uuid(7)) @db.Uuid
  campaignId          String    @db.Uuid
  questId             String
  name                String
  type                String    @default("side")
  description         String    @default("")
  completionCondition String?
  questGiverId        String?
  turnInNpcId         String?
  // Faza 0 — composite ref do grafu (kind+id). `locationId` zachowuje nazwę
  // dla zgodności call-site, ale teraz musi być parą z `locationKind`. AI
  // emituje nazwę → BE resolver (aiResolver.js) mapuje na composite ref
  // przed apply state.
  locationKind        String?
  locationId          String?
  reward              Json?
  // status: active|completed|stalled|failed (oś 4 — `stalled` 1st-class
  // dla rescue hooks; `failed` gdy questgiver dead i brak rescue path).
  status              String    @default("active")
  completedAt         DateTime? @db.Timestamptz
  forcedGiver         Boolean   @default(false)
  // Append-only ledger mutacji (oś 4): { ts, mutation: stall|fail|reroute,
  // reason, sceneIndex, payload }. Cap 10 entries — questDynamicsService
  // truncates head-first.
  mutationLog         Json      @default("[]")
  createdAt           DateTime  @default(now()) @db.Timestamptz
  updatedAt           DateTime  @updatedAt @db.Timestamptz

  campaign        Campaign                    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prerequisites   CampaignQuestPrerequisite[] @relation("questSide")
  prerequisiteFor CampaignQuestPrerequisite[] @relation("prereqSide")
  objectives      CampaignQuestObjective[]

  @@unique([campaignId, questId])
  @@index([campaignId])
  @@index([campaignId, status])
}

// F4 — replaces CampaignQuest.objectives JSONB. displayOrder is the
// canonical sort key (insertion order from AI). Replace-on-quest-update
// strategy (deleteMany + createMany), same pattern as F3 prerequisites.
model CampaignQuestObjective {
  id           BigInt        @id @default(autoincrement())
  questId      String        @db.Uuid
  displayOrder Int           @default(0)
  description  String
  progress     Int           @default(0)
  targetAmount Int           @default(1)
  // status: pending|done|locked|skipped|failed (rozszerzone w osi 1).
  // - pending: parents satisfied, do zrobienia
  // - done: ukończone
  // - locked: parents niespełnione (czeka na unlock z grafu)
  // - skipped: branchChoice w XOR group zamknął tę gałąź
  // - failed: failsOn match (np. questgiver dead) lub explicit questMutation
  status       String        @default("pending")
  // Per-objective JSONB bag — graf + diegetic + triggers:
  //   metadata.parents: string[]            — nodeKey-i które muszą być done
  //   metadata.unlocks: string[]            — nodeKey-i odblokowane przy done
  //   metadata.branchType: "and"|"path"|"or"  — XOR/równoległe/dowolny
  //   metadata.branchGroup: string          — id grupy branchy
  //   metadata.choiceLabel: string          — UI label dla wyboru
  //   metadata.failsOn: { npcDead?, locationDestroyed?, deadline? } (oś 4)
  //   metadata.discovered: boolean          — diegetic gating (oś 5)
  //   metadata.placeholderHint?: string     — vague hint w UI "???"
  //   metadata.lastKnownLocation?: string   — quest dynamics tick payload
  //   metadata.onComplete: { moveNpcToPlayer, message }   — trigger (legacy)
  metadata     Json          @default("{}")
  // Objective type tag (kill, escort, fetch, etc.) — visual badge + prompt hint.
  // Nullable for backward compat with objectives created before this feature.
  objectiveType String?
  // Tracks XP already awarded for this objective (prevents double-award).
  xpAwarded    Int           @default(0)
  // Stable string ref dla LLM (snake_case). Generowany przez questOffers,
  // BE waliduje [a-z0-9_]{1,40}. Resolver fallback do displayOrder index
  // dla legacy linear questów (bez nodeKey).
  nodeKey      String?
  quest        CampaignQuest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([questId, nodeKey])
  @@index([questId, displayOrder])
}

model CampaignLocationSummary {
  id              String   @id @default(uuid(7)) @db.Uuid
  campaignId      String   @db.Uuid
  locationName    String
  summary         String
  keyNpcs         Json     @default("[]")
  unresolvedHooks Json     @default("[]")
  sceneDigests    Json     @default("[]")
  sceneCount      Int      @default(0)
  lastVisitScene  Int      @default(0)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locationName])
  @@index([campaignId])
}

model CampaignDmAgent {
  campaignId    String   @id @db.Uuid
  lastUpdatedAt DateTime @default(now()) @db.Timestamptz

  campaign           Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  memoryEntries      CampaignDmMemoryEntry[]
  pendingHookEntries CampaignDmPendingHook[]
}

// F2 — child table replacing CampaignNPC.experienceLog JSONB array.
// FIFO-capped at 20 per campaignNpcId via trigger.
model CampaignNpcExperience {
  id            BigInt   @id @default(autoincrement())
  campaignNpcId String   @db.Uuid
