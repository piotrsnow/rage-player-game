  questId      String        @db.Uuid
  displayOrder Int           @default(0)
  description  String
  progress     Int           @default(0)
  targetAmount Int           @default(1)
  status       String        @default("pending")
  metadata     Json          @default("{}")
  objectiveType String?
  xpAwarded    Int           @default(0)
  nodeKey      String?
  quest        CampaignQuest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([questId, nodeKey])
  @@index([questId, displayOrder])
}

model CampaignLocationSummary {
  id              String   @id @default(uuid(7)) @db.Uuid
  campaignId      String   @db.Uuid
  locationName    String
  summary         String
  keyNpcs         Json     @default("[]")
  unresolvedHooks Json     @default("[]")
  sceneCount      Int      @default(0)
  lastSceneIndex  Int?
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locationName])
  @@index([campaignId])
}

model CampaignDmAgent {
  campaignId    String   @id @db.Uuid
  lastUpdatedAt DateTime @default(now()) @db.Timestamptz

  campaign           Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  memoryEntries      CampaignDmMemoryEntry[]
  pendingHookEntries CampaignDmPendingHook[]
}

model CampaignDmMemoryEntry {
  id         BigInt   @id @default(autoincrement())
  campaignId String   @db.Uuid
  at         DateTime @default(now()) @db.Timestamptz
  plannedFor String?
  status     String?
  summary    String

  agent CampaignDmAgent @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)

  @@index([campaignId, at])
}

model CampaignDmPendingHook {
  id          String   @id @default(uuid(7)) @db.Uuid
  campaignId  String   @db.Uuid
  kind        String   @default("generic")
  summary     String
  idealTiming String?
  priority    String   @default("normal")
  createdAt   DateTime @default(now()) @db.Timestamptz

  agent CampaignDmAgent @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Location — unified table (replaces WorldLocation + CampaignLocation).
//
// Scope discriminator:
//   campaignId IS NULL  → canonical (world-level, globally visible)
//   campaignId = <uuid> → scoped to one campaign (sandbox)
//
// Promotion = UPDATE SET campaignId = NULL, assign canonicalName.
// ═══════════════════════════════════════════════════════════════════════

model Location {
  id                 String       @id @default(uuid(7)) @db.Uuid
  // NULL = canonical (world); set = campaign-scoped
  campaignId         String?      @db.Uuid
  // Unique slug for canonical locations (NULL for campaign-scoped)
  canonicalName      String?
  displayName        String?
  description        String       @default("")
  category           String       @default("generic")
  region             String?
  parentLocationId   String?      @db.Uuid
  locationType       LocationType @default(generic)
  slotType           String?
  slotKind           String       @default("custom")
  maxKeyNpcs         Int          @default(10)
  maxSubLocations    Int          @default(5)
  regionX            Float        @default(0)
  regionY            Float        @default(0)
  positionConfidence Float        @default(0.5)
  subGridX           Int?
  subGridY           Int?
  knownByDefault     Boolean      @default(false)
  dangerLevel        DangerLevel  @default(safe)

  // Entity registry lifecycle
  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid

  aliases        Json    @default("[]")
  roomMetadata   Json?
  tags           Json    @default("[]")
  atmosphere     String?
  narrativeRoles Json    @default("[]")
  scale          Int     @default(5)
  nodeShape      String?
  nodeIcon       String?
  nodeImageUrl   String?

  tacticalGrid     Json?
  biome            String?
  anchorType       String?
  visitCount       Int       @default(0)
  npcsEncountered  Json      @default("[]")
  modificationsLog Json      @default("[]")
  dungeonState     Json?
  liberatedAt      DateTime? @db.Timestamptz

  embeddingText String?
  embedding     Unsupported("vector(1536)")?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  campaign       Campaign?  @relation("locationCampaign", fields: [campaignId], references: [id], onDelete: Cascade)
  parent         Location?  @relation("subloc", fields: [parentLocationId], references: [id], onDelete: SetNull)
  sublocations   Location[] @relation("subloc")

  outgoingRoads     Road[]              @relation("fromLoc")
  incomingRoads     Road[]              @relation("toLoc")
  outgoingEdges     LocationEdge[]      @relation("edgeFrom")
  incomingEdges     LocationEdge[]      @relation("edgeTo")
  campaignEdgesFrom CampaignEdge[]      @relation("campaignEdgeFrom")
  campaignEdgesTo   CampaignEdge[]      @relation("campaignEdgeTo")
  npcsHere          Npc[]               @relation("npcCurrentLoc")
  npcsHome          Npc[]               @relation("npcHomeLoc")
  knowledgeEntries  LocationKnowledge[]
  userDiscoveries   UserDiscoveredLocation[]
  npcKnownByEntries NpcKnownLocation[]
  campaignsHere     Campaign[]          @relation("campaignCurrentLoc")
  questsHere        CampaignQuest[]
  discoveredBy      DiscoveredLocation[]
  clearedBy         CharacterClearedDungeon[]
  movesFrom         NpcLocationMovement[] @relation("moveFrom")
  movesTo           NpcLocationMovement[] @relation("moveTo")
  promotionCandidates LocationPromotionCandidate[] @relation("promotionSource")

  @@unique([canonicalName])
  @@index([campaignId])
  @@index([region])
  @@index([parentLocationId])
  @@index([locationType])
  @@index([regionX, regionY])
  @@index([globallyActive, softDeletedAt])
}

// Road — canonical edges between locations (Dijkstra travel graph).
// DEPRECATED — migrating to LocationEdge (category='movement').
model Road {
  id             String      @id @default(uuid(7)) @db.Uuid
  fromLocationId String      @db.Uuid
  toLocationId   String      @db.Uuid
  distance       Float
  difficulty     DangerLevel @default(safe)
  terrainType    String      @default("road")
  direction      String?
  gated          Boolean     @default(false)
  gateHint       String?

  relationType    String  @default("road")
  bidirectional   Boolean @default(true)
  metadata        Json    @default("{}")
  visibility      String  @default("visible")
  risk            String?
  travelTime      Float?
  weight          Float?
  edgeDescription String? @map("description")
  confidence      Float?

  createdAt DateTime @default(now()) @db.Timestamptz

  from                Location                @relation("fromLoc", fields: [fromLocationId], references: [id], onDelete: Cascade)
  to                  Location                @relation("toLoc", fields: [toLocationId], references: [id], onDelete: Cascade)
  campaignDiscoveries CampaignEdgeDiscovery[]
  userDiscoveries     UserDiscoveredEdge[]

  @@index([fromLocationId])
  @@index([toLocationId])
}

// LocationEdge — rich semantic edges between any pair of locations.
// No more polymorphic kind+id — plain FKs to unified Location table.
model LocationEdge {
  id             String   @id @default(uuid(7)) @db.Uuid
  fromLocationId String   @db.Uuid
  toLocationId   String   @db.Uuid
  edgeType       String
  category       String
  bidirectional  Boolean  @default(true)
  weight         Float    @default(1.0)
  metadata       Json     @default("{}")
  discoveryState String   @default("unknown")
  confidence     Float    @default(1.0)
  campaignId     String?  @db.Uuid
  createdBy      String   @default("system")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz

  fromLocation Location  @relation("edgeFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation   Location  @relation("edgeTo", fields: [toLocationId], references: [id], onDelete: Cascade)
  campaign     Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([edgeType])
  @@index([category])
  @@index([campaignId])
}

// CampaignEdge — per-campaign edges (supplement canonical Roads/LocationEdges).
// No more polymorphic kind — plain FKs.
model CampaignEdge {
  id              String       @id @default(uuid(7)) @db.Uuid
  campaignId      String       @db.Uuid
  fromLocationId  String       @db.Uuid
  toLocationId    String       @db.Uuid
  relationType    String       @default("path")
  bidirectional   Boolean      @default(true)
  distance        Float?
  difficulty      DangerLevel?
  metadata        Json         @default("{}")
  visibility      String       @default("visible")
  risk            String?
  travelTime      Float?
  edgeDescription String?      @map("description")
  confidence      Float?
  createdAt       DateTime     @default(now()) @db.Timestamptz

  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromLocation Location @relation("campaignEdgeFrom", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation   Location @relation("campaignEdgeTo", fields: [toLocationId], references: [id], onDelete: Cascade)

  @@unique([campaignId, fromLocationId, toLocationId, relationType])
  @@index([campaignId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([relationType])
}

model UserWorldKnowledge {
  userId    String   @id @db.Uuid
  updatedAt DateTime @updatedAt @db.Timestamptz

  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  discoveredLocations UserDiscoveredLocation[]
  discoveredEdges     UserDiscoveredEdge[]
}

// Location knowledge (canonical location info — seeds, world facts)
model LocationKnowledge {
  id         BigInt   @id @default(autoincrement())
  locationId String   @db.Uuid
  content    String
  source     String
  kind       String
  confidence Float?
  similarity Float?
  addedAt    DateTime @default(now()) @db.Timestamptz

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, addedAt])
}

// Per-campaign fog-of-war for locations (plain FK, no polymorphic kind).
model DiscoveredLocation {
  campaignId   String         @db.Uuid
  locationId   String         @db.Uuid
  state        DiscoveryState
  discoveredAt DateTime       @default(now()) @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([campaignId, locationId])
  @@index([locationId])
  @@index([campaignId, state])
}

// Account-level fog-of-war for canonical locations.
model UserDiscoveredLocation {
  userId       String         @db.Uuid
  locationId   String         @db.Uuid
  state        DiscoveryState
  discoveredAt DateTime       @default(now()) @db.Timestamptz

  userKnowledge UserWorldKnowledge @relation(fields: [userId], references: [userId], onDelete: Cascade)
  location      Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([userId, locationId])
  @@index([locationId])
  @@index([userId, state])
}

// Per-user edge discovery (Road-based).
model UserDiscoveredEdge {
  userId       String   @db.Uuid
  edgeId       String   @db.Uuid
  discoveredAt DateTime @default(now()) @db.Timestamptz

  userKnowledge UserWorldKnowledge @relation(fields: [userId], references: [userId], onDelete: Cascade)
  edge          Road               @relation(fields: [edgeId], references: [id], onDelete: Cascade)

  @@id([userId, edgeId])
  @@index([edgeId])
}

// Per-campaign Road edge discovery.
model CampaignEdgeDiscovery {
  edgeId       String   @db.Uuid
  campaignId   String   @db.Uuid
  discoveredAt DateTime @default(now()) @db.Timestamptz

  edge     Road     @relation(fields: [edgeId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([edgeId, campaignId])
  @@index([campaignId])
}

// Dungeon clear tracking (plain FK to Location, no polymorphic kind).
model CharacterClearedDungeon {
  characterId String   @db.Uuid
  dungeonId   String   @db.Uuid
  clearedAt   DateTime @default(now()) @db.Timestamptz

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  dungeon   Location  @relation(fields: [dungeonId], references: [id], onDelete: Cascade)

  @@id([characterId, dungeonId])
  @@index([dungeonId])
}

model CampaignQuestPrerequisite {
  questId  String @db.Uuid
  prereqId String @db.Uuid

  quest  CampaignQuest @relation("questSide", fields: [questId], references: [id], onDelete: Cascade)
  prereq CampaignQuest @relation("prereqSide", fields: [prereqId], references: [id], onDelete: Cascade)

  @@id([questId, prereqId])
  @@index([prereqId])
}

