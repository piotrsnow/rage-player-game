generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  apiKeys      String   @default("{}") // Encrypted JSON: { openai, anthropic, elevenlabs, stability }
  settings     String   @default("{}") // JSON blob matching frontend settings shape
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns             Campaign[]
  characters            Character[]
  mediaAssets           MediaAsset[]
  achievements          Achievement[]
  multiplayerSessions   MultiplayerSession[]
  wanted3dEntries       Wanted3D[]
}

model Achievement {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  achievementId  String   // Frontend achievement key e.g. "first_campaign"
  unlockedAt     DateTime @default(now())
  campaignId     String?  @db.ObjectId
  metadata       String   @default("{}") // JSON: extra context about unlock

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Campaign {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  name           String   @default("")
  genre          String   @default("")
  tone           String   @default("")
  coreState      String   @default("{}") // Lean state: combat, world basics (minus npcs/knowledge/quests/character)
  characterIds   String[] @db.ObjectId   // Character record IDs participating in this campaign (1 in single-player, N in MP)
  totalCost      Float    @default(0)
  isPublic       Boolean  @default(false)
  shareToken     String?  @unique
  rating         Float    @default(0)
  playCount      Int      @default(0)
  lastSaved      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
}

model CampaignScene {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId       String   @db.ObjectId
  sceneIndex       Int
  narrative        String
  chosenAction     String?
  suggestedActions String   @default("[]")
  dialogueSegments String   @default("[]")
  imagePrompt      String?
  imageUrl         String?
  soundEffect      String?
  diceRoll         String?
  stateChanges     String?
  scenePacing      String?
  embeddingText    String?
  createdAt        DateTime @default(now())

  @@index([campaignId, sceneIndex])
}

model CampaignKnowledge {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId    String   @db.ObjectId
  entryType     String // "event" | "decision" | "plotThread" | "character" | "location"
  summary       String
  content       String // JSON: full entry data
  tags          String   @default("[]")
  importance    String?
  status        String?
  sceneIndex    Int?
  embeddingText String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignId, entryType])
}

model CampaignNPC {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId    String   @db.ObjectId
  npcId         String
  name          String
  gender        String   @default("unknown")
  role          String?
  personality   String?
  attitude      String   @default("neutral")
  disposition   Int      @default(0)
  alive         Boolean  @default(true)
  lastLocation  String?
  factionId     String?
  notes         String?
  relationships String   @default("[]")
  embeddingText String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignId])
  @@unique([campaignId, npcId])
}

model CampaignCodex {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId     String   @db.ObjectId
  codexKey       String
  name           String
  category       String
  tags           String   @default("[]")
  fragments      String // JSON array of fragments
  relatedEntries String   @default("[]")
  embeddingText  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([campaignId])
  @@unique([campaignId, codexKey])
}

model CampaignQuest {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  campaignId           String    @db.ObjectId
  questId              String
  name                 String
  type                 String    @default("side")
  description          String    @default("")
  completionCondition  String?
  questGiverId         String?
  turnInNpcId          String?
  locationId           String?
  prerequisiteQuestIds String    @default("[]")
  objectives           String    @default("[]")
  reward               String?
  status               String    @default("active") // "active" | "completed"
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([campaignId])
  @@unique([campaignId, questId])
}

model CampaignLocationSummary {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  campaignId      String   @db.ObjectId
  locationName    String
  summary         String
  keyNpcs         String   @default("[]") // JSON array of NPC names
  unresolvedHooks String   @default("[]") // JSON array of unresolved plot hooks
  sceneCount      Int      @default(0)
  lastVisitScene  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([campaignId])
  @@unique([campaignId, locationName])
}

model Character {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  name            String
  age             Int      @default(23)
  gender          String   @default("")
  species         String
  // RPGon stats
  attributes      String   @default("{}") // JSON: { sila, inteligencja, charyzma, zrecznosc, wytrzymalosc, szczescie }
  skills          String   @default("{}") // JSON: { "SkillName": { level: N, xp: N }, ... }
  wounds          Int      @default(0)
  maxWounds       Int      @default(0)
  movement        Int      @default(4)
  characterLevel  Int      @default(1)
  characterXp     Int      @default(0)
  attributePoints Int      @default(0)
  // Magic
  mana            String   @default("{\"current\":0,\"max\":0}") // JSON: { current, max }
  spells          String   @default("{\"known\":[],\"usageCounts\":{},\"scrolls\":[]}") // JSON: { known, usageCounts, scrolls }
  // Inventory & equipment
  inventory       String   @default("[]") // JSON array of items (each with optional baseType)
  materialBag     String   @default("[]") // JSON array of crafting materials
  money           String   @default("{\"gold\":0,\"silver\":0,\"copper\":0}") // JSON: { gold, silver, copper }
  equipped        String   @default("{\"mainHand\":null,\"offHand\":null,\"armour\":null}") // JSON: { mainHand, offHand, armour }
  // Status & needs
  statuses        String   @default("[]") // JSON array of active statuses
  needs           String   @default("{\"hunger\":100,\"thirst\":100,\"bladder\":100,\"hygiene\":100,\"rest\":100}") // JSON
  // Narrative
  backstory       String   @default("")
  customAttackPresets String @default("[]") // JSON array of custom attack preset strings
  // Presentation
  portraitUrl     String   @default("")
  voiceId         String   @default("")
  voiceName       String   @default("")
  // Library metadata
  campaignCount   Int      @default(0)
  // Legacy WFRP fields kept for now (CharacterCreationModal still references some)
  careerData      String   @default("{}")
  characteristics String   @default("{}")
  advances        String   @default("{}")
  xp              Int      @default(0)
  xpSpent         Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MultiplayerSession {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  roomCode     String   @unique
  hostId       String   @db.ObjectId
  phase        String
  players      String   // JSON array of player data (without ws). Each entry: { odId, name, characterId, ... }
  characterIds String[] @db.ObjectId   // All Character record IDs participating in this room (parallel to players)
  gameState    String   // JSON: world / scenes / combat — character data is NOT embedded, fetched via characterIds
  settings     String   // JSON room settings
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  host User @relation(fields: [hostId], references: [id])
}

model MediaAsset {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  campaignId     String?  @db.ObjectId
  key            String   @unique // Content-addressable hash key e.g. "images/a1b2c3.png"
  type           String   // "image" | "music" | "sfx" | "tts"
  contentType    String   // MIME type
  size           Int      @default(0)
  backend        String   @default("local") // "local" | "gcp"
  path           String   // Storage path (filesystem path or GCS object name)
  metadata       String   @default("{}") // JSON: generation params for cache lookups
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([campaignId])
}

model PrefabAsset {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  key            String   @unique // Stable shared key, usually matching storage path
  category       String   @default("")
  fileName       String
  contentType    String   // MIME type
  size           Int      @default(0)
  backend        String   @default("local") // "local" | "gcp"
  path           String   @unique // Storage path (filesystem path or GCS object name)
  metadata       String   @default("{}") // JSON: import/sync metadata
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastAccessedAt DateTime @default(now())

  @@index([category])
  @@index([fileName])
}

model Wanted3D {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  campaignId       String?  @db.ObjectId
  objectKey        String   @unique
  entityKind       String   @default("object")
  objectId         String
  objectName       String
  objectType       String
  objectDescription String  @default("")
  sceneId          String   @default("")
  sceneText        String   @default("")
  suggestedModelId String   @default("")
  suggestedCategory String  @default("")
  suggestedFile    String   @default("")
  matchScore       Int      @default(0)
  alreadyExists    Boolean  @default(false)
  status           String   @default("review")
  requestCount     Int      @default(1)
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@map("3dwanted")
}
