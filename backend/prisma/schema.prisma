  originRow Int      @default(0)
  cols      Int?
  rows      Int?
  cells     Json     @default("{}")
  traits    Json     @default("{}")
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tileset Tileset @relation(fields: [tilesetId], references: [id], onDelete: Cascade)
  tiles   Tile[]

  @@index([tilesetId])
}

model ConnectionRule {
  id          String   @id @default(uuid(7)) @db.Uuid
  packId      String   @db.Uuid
  name        String   @default("")
  leftTraits  Json     @default("{}")
  rightTraits Json     @default("{}")
  via         String   @default("autotile_group")
  viaRef      Json     @default("{}")
  priority    Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  pack TilesetPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
}

model MapDoc {
  id              String   @id @default(uuid(7)) @db.Uuid
  userId          String   @db.Uuid
  name            String
  size            Json     @default("[64,64]")
  projectTilesize Int      @default(24)
  packIds         String[] @default([])
  layers          Json     @default("{}")
  collision       String   @default("")
  objects         Json     @default("[]")
  meta            Json     @default("{}")
  campaignId      String?  @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  @@index([userId])
}

model MapActor {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @db.Uuid
  name       String
  appearance Json     @default("{}")
  tags       String[] @default([])
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════
// Topic History
// ═══════════════════════════════════════════════════════════════════════

model TopicHistory {
  id             String   @id @default(uuid(7)) @db.Uuid
  userId         String   @db.Uuid
  seedText       String
  generatedTopic String
  genre          String   @default("")
  tone           String   @default("")
  createdAt      DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════
// Server Settings
// ═══════════════════════════════════════════════════════════════════════

model ServerSettings {
  id                String   @id @default("singleton")
  voiceConfig       Json     @default("{}")
  modelOverrides    Json     @default("{}")
  sceneModelConfig  Json     @default("{}")
  fontConfig        Json     @default("{}")
  difficultyScaling Json     @default("{}")
  billingEnabled    Boolean  @default(false)
  updatedAt         DateTime @updatedAt @db.Timestamptz
}

// ═══════════════════════════════════════════════════════════════════════
// LLM Call Log
// ═══════════════════════════════════════════════════════════════════════

model LlmCallLog {
  id         String    @id @default(uuid(7)) @db.Uuid
  userId     String    @db.Uuid
  type       String
  label      String    @default("")
  provider   String?
  model      String?
  status     String    @default("pending")
  durationMs Int?
  error      String?
  request    Json?
  response   Json?
  startedAt  DateTime  @default(now()) @db.Timestamptz
  finishedAt DateTime? @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
}

// ═══════════════════════════════════════════════════════════════════════
// System metadata
// ═══════════════════════════════════════════════════════════════════════

model SystemMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @db.Timestamptz
}

// ═══════════════════════════════════════════════════════════════════════
// Global spell catalog
// ═══════════════════════════════════════════════════════════════════════

model CustomSpell {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String   @unique
  school      String?
  description String?
  icon        String?
  manaCost    Int      @default(2)
  combatStats Json?
  createdById String?  @db.Uuid
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @db.Timestamptz

  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid

  @@index([globallyActive, softDeletedAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Global item definitions
// ═══════════════════════════════════════════════════════════════════════

model WorldItemDefinition {
  id               String    @id @default(uuid(7)) @db.Uuid
  itemKey          String    @unique
  displayName      String
  baseType         String?
  description      String    @default("")
  props            Json      @default("{}")
  globallyActive   Boolean   @default(true)
  softDeletedAt    DateTime? @db.Timestamptz
  originCampaignId String?   @db.Uuid
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  @@index([globallyActive, softDeletedAt])
}

// ═══════════════════════════════════════════════════════════════════════
// Spell Images
// ═══════════════════════════════════════════════════════════════════════

model SpellImage {
  name        String   @id
  imageUrl    String
  imagePrompt String?
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz
}

// ═══════════════════════════════════════════════════════════════════════
// Location Sprite Jobs
// ═══════════════════════════════════════════════════════════════════════

model LocationSpriteJob {
  id          String    @id @default(uuid(7)) @db.Uuid
  status      String    @default("pending")
  total       Int       @default(0)
  done        Int       @default(0)
  failed      Int       @default(0)
  concurrency Int       @default(3)
  createdBy   String?   @db.Uuid
  startedAt   DateTime? @db.Timestamptz
  finishedAt  DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  items LocationSpriteJobItem[]

  @@index([status])
}

model LocationSpriteJobItem {
  id           String   @id @default(uuid(7)) @db.Uuid
  jobId        String   @db.Uuid
  job          LocationSpriteJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  locationId   String   @db.Uuid
  status       String   @default("pending")
  attempts     Int      @default(0)
  error        String?
  resultingUrl String?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([jobId, status])
  @@unique([jobId, locationId])
}
