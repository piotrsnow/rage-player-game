# Required
JWT_SECRET=change-me-to-a-strong-random-string
API_KEY_ENCRYPTION_SECRET=change-me-to-another-strong-random-string

# MongoDB (docker-compose uses the internal service name by default)
# For Cloud Run / Atlas: mongodb+srv://user:pass@cluster.mongodb.net/rpgon
# DATABASE_URL=mongodb://localhost:27017/rpgon

# CORS origin (set to your frontend URL in production)
# CORS_ORIGIN=https://your-app.run.app

# Media storage: "local" (default) or "gcp"
# MEDIA_BACKEND=gcp
# GCS_BUCKET_NAME=your-bucket-name
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
