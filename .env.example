# Required
JWT_SECRET=change-me-to-a-strong-random-string
API_KEY_ENCRYPTION_SECRET=change-me-to-another-strong-random-string

# ───────────────────────────────────────────────────────────────────────
# Database mode — local Postgres (docker-compose) vs managed (Neon)
# ───────────────────────────────────────────────────────────────────────
# LOCAL MODE (default):
#   - Keep COMPOSE_PROFILES=local-db (spins up the bundled `db` service)
#   - Leave DATABASE_URL UNSET (compose defaults the backend container to
#     `postgresql://rpgon:rpgon@db:5432/rpgon` via docker network)
#   - `backend/.env` keeps DATABASE_URL=postgresql://rpgon:rpgon@localhost:5432/rpgon
#     for host-side `prisma migrate`
COMPOSE_PROFILES=local-db
# DATABASE_URL=postgresql://rpgon:rpgon@db:5432/rpgon
#
# NEON MODE:
#   - Comment out COMPOSE_PROFILES (or set empty) — skip the local `db` service
#   - Uncomment + fill in the Neon DATABASE_URL below (use the `-pooler` host
#     for built-in PgBouncer; sslmode=require is mandatory)
#   - Mirror the same URL in `backend/.env` for host-side `prisma migrate`
# COMPOSE_PROFILES=
# DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<database>?sslmode=require

# CORS origin (set to your frontend URL in production)
# CORS_ORIGIN=https://your-app.run.app

# Media storage: "local" (default) or "gcp"
# MEDIA_BACKEND=gcp
# GCS_BUCKET_NAME=your-bucket-name
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# --- Stable Diffusion WebUI (Automatic1111) — optional ---
# SD_WEBUI_URL=http://host.docker.internal:7860
# SD_WEBUI_SAMPLER=DPM++ 2M Karras
# SD_WEBUI_STEPS=25
# SD_WEBUI_CFG=7.0
# SD_WEBUI_HIRES_FIX=1
# SD_WEBUI_SCENE_WIDTH=1344
# SD_WEBUI_SCENE_HEIGHT=768
